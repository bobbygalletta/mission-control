 \"maxTokens\": 65536,\n                \"cost\": {\n                  \"input\": 0,\n                  \"output\": 0,\n                  \"cacheRead\": 0,\n                  \"cacheWrite\": 0\n                },\n                \"api\": \"openai-completions\"\n              }\n            ]\n          },\n          \"ollama\": {\n            \"baseUrl\": \"http://127.0.0.1:11434\",\n            \"api\": \"ollama\",\n            \"models\": [\n              {\n                \"id\": \"glm-5.1:cloud\",\n                \"name\": \"GLM-5.1 (Cloud)\",\n                \"input\": [\n                  \"text\"\n                ],\n                \"contextWindow\": 200000,\n                \"maxTokens\": 131072,\n                \"cost\": {\n                  \"input\": 0,\n                  \"output\": 0,\n                  \"cacheRead\": 0,\n                  \"cacheWrite\": 0\n                }\n              }\n            ]\n          }\n        }\n      },\n      \"agents\": {\n        \"defaults\": {\n          \"model\": {\n            \"primary\": \"openai-codex/gpt-5.4\"\n          },\n          \"models\": {\n            \"openai-codex/gpt-5.4\": {}\n          },\n          \"workspace\": \"/Users/bobbygalletta/.openclaw/workspace\",\n          \"compaction\": {\n            \"reserveTokensFloor\": 20000\n          },\n          \"timeoutSeconds\": 1200,\n          \"subagents\": {\n            \"runTimeoutSeconds\": 1200,\n            \"announceTimeoutMs\": 600000\n          },\n          \"memorySearch\": {\n            \"provider\": \"local\",\n            \"enabled\": true\n          }\n        },\n        \"list\": [\n          {\n            \"id\": \"main\",\n            \"model\": \"minimax-portal/MiniMax-M2.7\",\n            \"tools\": {\n              \"profile\": \"full\"\n            }\n          },\n          {\n            \"id\": \"emmy\",\n            \"workspace\": \"/Users/bobbygalletta/.openclaw/workspace-emmy\",\n            \"model\": \"