erve audio files\n  if (req.method === 'GET' && req.url.startsWith('/audio/')) {\n    const filename = path.basename(req.url);\n    const filePath = path.join(AUDIO_DIR, filename);\n    if (fs.existsSync(filePath)) {\n      res.writeHead(200, { 'Content-Type': 'audio/mpeg' });\n      fs.createReadStream(filePath).pipe(res);\n    } else {\n      res.writeHead(404);\n      res.end('Not found');\n    }\n    return;\n  }\n\n  // Receive transcribed speech from browser\n  if (req.method === 'POST' && req.url === '/talk') {\n    let body = '';\n    req.on('data', chunk => body += chunk);\n    req.on('end', () => {\n      try {\n        const { text } = JSON.parse(body);\n\n        messages.push({\n          from: 'user',\n          text: text,\n          timestamp: Date.now()\n        });\n        saveMessages();\n\n        res.writeHead(200, { 'Content-Type': 'application/json' });\n        res.end(JSON.stringify({ received: true, queuePosition: messages.length }));\n      } catch(e) {\n        res.writeHead(400);\n        res.end('Bad request');\n      }\n    });\n    return;\n  }\n\n  // Check for new messages (Dean polls this)\n  if (req.method === 'GET' && req.url === '/messages') {\n    const since = parseInt(req.headers['x-since'] || '0');\n    const newMessages = messages.filter(m => m.timestamp > since);\n    res.writeHead(200, { 'Content-Type': 'application/json' });\n    res.end(JSON.stringify({ messages: newMessages }));\n    return;\n  }\n\n  // Dean posts reply here\n  if (req.method === 'POST' && req.url === '/reply') {\n    let body = '';\n    req.on('data', chunk => body += chunk);\n    req.on('end', () => {\n      try {\n        const { text, fromDean } = JSON.parse(body);\n        if (fromDean) {\n          textToAudio(text, (mp3Path) => {\n            if (mp3Path) {\n              messages.push({\n                from: 'dean',\n                text: text,\n                audioFile: `/talk/audio/${path.basename(mp3Path)}`,\n                timestamp: Date.now()\n              });\n              saveMessages();\n            }\n            res.writeHead(200, { 'Content-Type': 'application/json' });\n            res.end(JSON.stringify({ ok: true, audioFile: mp3Path ? `/talk/audio/${path.basename(mp3Path)}` : null }));\n          });\n        } else {\n          res.writeHead(200);\n          res.end(JSON.stringify({ ok: true }));\n        }\n      } catch(e) {\n        res.writeHead(400);\n        res.end('Bad request');\n      }\n    });\n    return;\n  }\n\n  res.writeHead(404);\n  res.end('Not found');\n});\n\nserver.listen(PORT, () => {\n  console.log(`Telephone server running on port ${PORT}`);\n});","path":"/Users/bobbygalletta/Desktop/Telephone/server.js"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":2881,"output":1127,"cacheRead":86592,"cacheWrite":0,"totalTokens":90600,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777663237534,"responseId":"064430063712c9ade86dc0ef9b8b12ee"}}
