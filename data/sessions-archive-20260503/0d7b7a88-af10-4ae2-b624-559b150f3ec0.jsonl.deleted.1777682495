1FA78}]|[\\u{1FA79}-\\u{1FA7A}]|[\\u{1FA7B}-\\u{1FA7C}]|[\\u{1FA7D}]|[\\u{1FA7E}]|[\\u{1FA7F}]|[\\u{1FA80}-\\u{1FA82}]|[\\u{1FA83}]|[\\u{1FA84}]|[\\u{1FA85}]|[\\u{1FA86}]|[\\u{1FA87}]|[\\u{1FA88}]|[\\u{1FA89}]|[\\u{1FA8A}]|[\\u{1FA8B}]|[\\u{1FA8C}]|[\\u{1FA8D}]|[\\u{1FA8E}]|[\\u{1FA8F}]|[\\u{1FA90}]|[\\u{1FA91}]|[\\u{1FA92}]|[\\u{1FA93}]|[\\u{1FA94}]|[\\u{1FA95}]|[\\u{1FA96}]|[\\u{1FA97}]|[\\u{1FA98}]|[\\u{1FA99}]|[\\u{1FA9A}]|[\\u{1FA9B}]|[\\u{1FA9C}]|[\\u{1FA9D}]|[\\u{1FA9E}]|[\\u{1FA9F}]|[\\u{1FAA0}]|[\\u{1FAA1}]|[\\u{1FAA2}]|[\\u{1FAA3}]|[\\u{1FAA4}]|[\\u{1FAA5}]|[\\u{1FAA6}]|[\\u{1FAA7}]|[\\u{1FAA8}]|[\\u{1FAA9}]|[\\u{1FAAA}]|[\\u{1FAAB}]|[\\u{1FAAC}]|[\\u{1FAD0}-\\u{1FAD9}]|[\\u{1FAE0}-\\u{1FAE7}]|[\\u{1FAF0}-\\u{1FAF6}]|[\\u{FE0F}]|[\\u{200D}]|[\\u{20E3}]|[\\u{E0020}-\\u{E007F}]|[\\u{FE0E}]|[\\u{FE0F}]/gu;\n\nif (!fs.existsSync(AUDIO_DIR)) fs.mkdirSync(AUDIO_DIR, { recursive: true });\n\nlet lastCheck = 0;\nif (fs.existsSync(STATE_FILE)) {\n  try { lastCheck = parseInt(fs.readFileSync(STATE_FILE, 'utf8')) || 0; } catch(e) {}\n}\n\nfunction getGatewayToken() {\n  try {\n    const config = JSON.parse(fs.readFileSync('/Users/bobbygalletta/.openclaw/openclaw.json', 'utf8'));\n    return config.gateway?.auth?.token || '';\n  } catch(e) { return ''; }\n}\n\nfunction saveLastCheck(ts) {\n  fs.writeFileSync(STATE_FILE, String(ts));\n}\n\nfunction getNewMessages() {\n  return new Promise((resolve) => {\n    const req = http.get(`http://localhost:${PORT_DEAN}/messages?since=${lastCheck}`, (res) => {\n      let data = '';\n      res.on('data', chunk => data += chunk);\n      res.on('end', () => {\n        try { resolve(JSON.parse(data).messages || []); }\n        catch(e) { resolve([]); }\n      });\n    });\n    req.on('error', () => resolve([]));\n  });\n}\n\nfunction postReply(text) {\n  return new Promise((resolve) => {\n    const body = JSON.stringify({ text, fromDean: true });\n    const req = http.request({\n      hostname: 'localhost', port: PORT_DEAN, path: '/reply',\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) }\n    }, (res) => {\n      let data = '';\n      res.on('data', c => data += c);\n      res.on('end', () => { try { resolve(JSON.parse(data)); } catch(e) { resolve({}); } });\n    });\n    req.on('error', () => resolve({}));\n    req.write(body);\n    req.end();\n  });\n}\n\nfunction textToAudio(text, callback) {\n  const ts = Date.now();\n  const mp3Path = path.join(AUDIO_DIR, `reply_${ts}.mp3`);\n  const aiffPath = `/tmp/dean_telephone_${ts}.aiff`;\n\n  try {\n    // Remove ALL emoji, special chars, and problem characters\n    const clean = text\n      .replace(EMOJI_REGEX, '')\n      .replace(/[\"\\\\'‘’\"\"«»]/g, '')\n      .replace(/[^\\x00-\\x7F]/g, '') // Remove non-ASCII\n      .replace(/\\s+/g, ' ')\n      .trim();\n    \n    console.log(`[Telephone] TTS: \"${clean}\"`);\n    \n    if (!clean) { callback(null); return; }\n\n    execSync(`say \"${clean}\" -o \"${aiffPath}\"`, { stdio: 'pipe' });\n    execSync(`ffmpeg -i \"${aiffPath}\" \"${mp3Path}\" -y`, { stdio: 'pipe' });\n    try { fs.unlinkSync(aiffPath); } catch(e) {}\n    callback(mp3Path);\n  } catch(e) {\n    console.error('[Telephone] TTS error:', e.message);\n    callback(null);\n  }\n}\n\nfunction callAI(userText, callback) {\n  const token = getGatewayToken();\n  \n  const body = JSON.stringify({\n    model: 'openclaw/main',\n    messages: [\n      { role: 'system', content: 'You are Dean, Bobby\\'s main AI assistant on the Telephone app. Keep responses SHORT — 1 to 2 sentences max. Casual, conversational, like talking to a friend. Be warm and direct. Do NOT use emoji — they cause problems. Bobby is speaking to you through a voice app on his iPhone.' },\n      { role: 'user', content: userText }\n    ],\n    max_tokens: 150,\n    temperature: 0.8\n  });\n\n  const req = http.request({\n    hostname: '127.0.0.1',\n    port: GATEWAY_PORT,\n    path: '/v1/chat/completions',\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${token}`,\n      'Content-Length': Buffer.byteLength(body)\n    }\n  }, (res) => {\n    let data = '';\n    res.on('data', chunk => data += chunk);\n    res.on('end', () => {\n      try {\n        const parsed = JSON.parse(data);\n        const reply = parsed.choices?.[0]?.message?.content?.trim();\n        if (reply) {\n          callback(reply);\n        } else {\n          console.error('[Telephone] Empty AI response:', data.substring(0, 200));\n          callback(\"I'm here Bobby, say something!\");\n        }\n      } catch(e) {\n        console.error('[Telephone] AI parse error:', e.message, data.substring(0, 200));\n        callback(\"I'm here Bobby, say something!\");\n      }\n    });\n  });\n\n  req.on('error', (e) => {\n    console.error('[Telephone] AI connection error:', e.message);\n    callback(\"I'm here Bobby, say something!\");\n  });\n\n  req.write(body);\n  req.end();\n}\n\nasync function processLoop() {\n  try {\n    const messages = await getNewMessages();\n    \n    for (const msg of messages) {\n      if (msg.from === 'user' && msg.text && !msg.text.includes('Could not transcribe')) {\n        console.log(`[Telephone] Bobby said: ${msg.text}`);\n        saveLastCheck(msg.timestamp);\n        \n        callAI(msg.text, async (reply) => {\n          console.log(`[Telephone] Dean says: ${reply}`);\n          \n          textToAudio(reply, async (mp3Path) => {\n            if (mp3Path) {\n              await postReply(reply);\n              console.log(`[Telephone] Audio reply posted`);\n            }\n          });\n        });\n      }\n    }\n  } catch(e) {\n    console.error('[Telephone] Process error:', e.message);\n  }\n  \n  setTimeout(processLoop, 2500);\n}\n\nconsole.log('[Telephone] Dean started — AI connected to OpenClaw');\nprocessLoop();","path":"/Users/bobbygalletta/Desktop/Telephone/dean.js"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":273,"output":4937,"cacheRead":107840,"cacheWrite":0,"totalTokens":113050,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777682016246,"responseId":"06447960353e7a6709c3754941165d85"}}
