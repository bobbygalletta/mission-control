    }\n      },\n      \"plugins\": {\n        \"allow\": [\n          \"lossless-claw\",\n          \"telegram\",\n          \"minimax\",\n          \"browser\",\n          \"xai\",\n          \"brave\",\n          \"memory-core\",\n          \"ollama\",\n          \"openai\"\n        ],\n        \"entries\": {\n          \"telegram\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"brave\": {\n            \"enabled\": true,\n            \"config\": {\n              \"webSearch\": {\n                \"apiKey\": \"__OPEN…ED__\"\n              }\n            }\n          },\n          \"minimax\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"browser\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"xai\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"memory-core\": {\n            \"enabled\": true,\n            \"config\": {\n              \"dreaming\": {\n                \"enabled\": true,\n                \"frequency\": \"0 3 * * *\",\n                \"timezone\": \"America/New_York\"\n              }\n            }\n          },\n          \"ollama\": {\n            \"enabled\": true,\n            \"config\": {}\n          },\n          \"openai\": {\n            \"enabled\": true,\n            \"config\": {\n              \"personality\": \"friendly\"\n            }\n          },\n          \"lossless-claw\": {\n            \"config\": {}\n          }\n        }\n      },\n      \"messages\": {\n        \"ackReactionScope\": \"group-mentions\"\n      }\n    },\n    \"hash\": \"41331f2c255967d6a4c9566f5712f9ee0e76fb93995c07d0fed8170c1e64a2d8\",\n    \"issues\": [],\n    \"warnings\": [],\n    \"legacyIssues\": []\n  }\n}[... 81780 more characters truncated]"}],"details":{"persistedDetailsTruncated":true,"originalDetailsBytesAtLeast":8193,"originalDetailKeys":["ok","result"]},"isError":false,"time