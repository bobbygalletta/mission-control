{"type":"message","id":"5117704e","parentId":"35fc1dab","timestamp":"2026-05-03T04:10:38.156Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I can see the structure. I need to:\n1. Get the media URL for the video\n2. But the `url` field for video media is not showing up — that's because for uploaded videos, X doesn't expose the raw URL in the API (it's behind their CDN with signed URLs)\n\nHowever, the expanded URL `https://x.com/marlowxbt/status/2050011880886784235/video/1` is the video page URL. I can use yt-dlp to download from that URL.\n\nLet me write a proper script that:\n1. Fetches each liked tweet with media\n2. Gets the video page URL\n3. Downloads with yt-dlp\n4. Transcribes with whisper\n\n\n5. Saves the transcript, summary, and link to a JSON file\n6. Cleans up the video afterwards\n","thinkingSignature":"0ac8359c9667448f25a84891998bb571f49fa0355b509f6b5c29e79242bb2886"},{"type":"text","text":"\n\nGot it working. Now let me write the full system — I'll scan all 1,132 likes for video posts, download them, transcribe, save the transcript + summary, then delete the video.\n"},{"type":"toolCall","id":"call_function_qoc0y9e2ko0v_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nProcess all liked tweets that contain videos:\n1. Fetch each tweet with media info\n2. Download the video via yt-dlp\n3. Transcribe via whisper\n4. Save transcript + summary + link to JSON\n5. Delete video to save storage\n6. Track progress so we can resume\n\"\"\"\n\nimport json\nimport os\nimport subprocess\nimport sys\nimport time\nfrom datetime import datetime\n\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace-x/x-data\")\nLIKES_FILE = os.path.join(DATA_DIR, \"all-likes.json\")\nTRANSCRIPT_DIR = os.path.join(DATA_DIR, \"video-transcripts\")\nPROGRESS_FILE = os.path.join(DATA_DIR, \"transcribe-progress.json\")\nPROCESSED_LOG = os.path.join(DATA_DIR, \"transcribed-videos.json\")\nTEMP_DIR = \"/tmp/x-video-transcribe\"\n\nos.makedirs(TRANSCRIPT_DIR, exist_ok=True)\nos.makedirs(TEMP_DIR, exist_ok=True)\n\ndef load_progress():\n    if os.path.exists(PROGRESS_FILE):\n        with open(PROGRESS_FILE) as f:\n            return json.load(f)\n    return {\"processed\": [], \"last_tweet_id\": None}\n\ndef save_progress(progress):\n    with open(PROGRESS_FILE, 'w') as f:\n        json.dump(progress, f, indent=2)\n\ndef load_processed():\n    if os.path.exists(PROCESSED_LOG):\n        with open(PROCESSED_LOG) as f:\n            return set(json.load(f))\n    return set()\n\ndef mark_processed(tid):\n    processed = load_processed()\n    processed.add(tid)\n    with open(PROCESSED_LOG, 'w') as f:\n        json.dump(list(processed), f, indent=2)\n\ndef get_video_tweets():\n    \"\"\"Get all tweet IDs from likes that have videos.\"\"\"\n    with open(LIKES_FILE) as f:\n        likes = json.load(f)\n    \n    # Get all tweet IDs with their entities info from initial fetch\n    # But we need to re-fetch them with media expansions\n    tweet_ids = []\n    for tweet in likes:\n        tid = tweet.get('id', '')\n        # Check if tweet text mentions video/embed\n        text = tweet.get('text', '')\n        if 'x.com' in text and ('/video/' in text or 'pic.x.com' in text):\n            tweet_ids.append(tid)\n    \n    print(f\"Found {len(tweet_ids)} potential video tweets from likes\")\n    return tweet_ids\n\ndef fetch_tweet_media(tid):\n    \"\"\"Get video URL for a tweet via X API.\"\"\"\n    cmd = [\n        'xurl', f'/2/tweets/{tid}?tweet.fields=created_at&expansions=attachments.media_keys&media.fields=type,url,duration_ms'\n    ]\n    result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)\n    if result.returncode != 0:\n        return None\n    \n    try:\n        d = json.loads(result.stdout)\n        includes = d.get('includes', {})\n        media_list = includes.get('media', [])\n        \n        for m in media_list:\n            if m.get('type') == 'video':\n                return {\n                    'tweet_id': tid,\n                    'url': m.get('url'),  # This may be None for user-uploaded videos\n                    'duration_ms': m.get('duration_ms'),\n                    'media_key': m.get('media_key'),\n                    'created_at': d.get('data', {}).get('created_at')\n                }\n    except Exception as e:\n        print(f\"    Parse error: {e}\")\n    \n    return None\n\ndef download_video(tid, tweet_url):\n    \"\"\"Download video from tweet URL using yt-dlp.\"\"\"\n    out_file = os.path.join(TEMP_DIR, f\"{tid}.m4a\")\n    \n    # Try the tweet video page URL\n    video_url = f\"https://x.com/i/status/{tid}\"\n    \n    cmd = [\n        'yt-dlp', '-x', '--audio-format', 'm4a',\n        '--audio-quality', '0',\n        '-o', out_file,\n        '--no-playlist',\n        '--quiet',\n        video_url\n    ]\n    \n    result = subprocess.run(cmd, capture_output=True, text=True, timeout=120)\n    \n    if result.returncode == 0 and os.path.exists(out_file):\n        size = os.path.getsize(out_file)\n        if size > 5000:\n            return out_file\n    \n    return None\n\ndef transcribe_audio(audio_file, tid):\n    \"\"\"Transcribe audio file with whisper.\"\"\"\n    out_file = os.path.join(TEMP_DIR, f\"{tid}.txt\")\n    \n    cmd = [\n        'whisper', audio_file,\n        '--model', 'medium',\n        '--output_dir', TEMP_DIR,\n        '--output_format', 'txt',\n        '--language', 'English',\n        '--verbose', 'False'\n    ]\n    \n    result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)\n    \n    # Whisper outputs to the same dir as input with .txt extension\n    expected_txt = audio_file.replace('.m4a', '.txt')\n    if os.path.exists(expected_txt):\n        with open(expected_txt, 'r', errors='ignore') as f:\n            return f.read().strip()\n    \n    if os.path.exists(out_file):\n        with open(out_file, 'r', errors='ignore') as f:\n            return f.read().strip()\n    \n    return None\n\ndef summarize_transcript(transcript, word_count):\n    \"\"\"Generate a summary from transcript.\"\"\"\n    if not transcript:\n        return None\n    \n    # Take first 400 chars as hook + word count\n    summary = transcript[:400].strip()\n    if len(transcript) > 400:\n        summary += '...'\n    summary += f\"\\n\\n[{word_count} words]\"\n    \n    return summary\n\ndef main():\n    progress = load_progress()\n    processed_set = load_processed()\n    processed_list = progress.get('processed', [])\n    \n    print(f\"Total likes: 1132\")\n    print(f\"Already processed: {len(processed_list)}\")\n    \n    tweet_ids = get_video_tweets()\n    print(f\"Video tweets to check: {len(tweet_ids)}\")\n    \n    to_process = [tid for tid in tweet_ids if tid not in processed_list]\n    print(f\"New to process: {len(to_process)}\")\n    \n    if not to_process:\n        print(\"Nothing new to transcribe.\")\n        return\n    \n    transcribed_count = 0\n    error_count = 0\n    \n    for i, tid in enumerate(to_process):\n        print(f\"\\n[{i+1}/{len(to_process)}] {tid}\")\n        \n        # Fetch media info\n        print(f\"  Fetching tweet info...\")\n        media_info = fetch_tweet_media(tid)\n        if not media_info:\n            print(f\"  Skipping: no video found\")\n            error_count += 1\n            processed_list.append(tid)\n            progress['processed'] = processed_list\n            save_progress(progress)\n            continue\n        \n        # Download\n        print(f\"  Downloading...\")\n        tweet_url = f\"https://x.com/i/status/{tid}\"\n        audio_file = download_video(tid, tweet_url)\n        \n        if not audio_file or not os.path.exists(audio_file):\n            print(f\"  Download failed, trying alternate method...\")\n            # Try the expanded URL from the tweet text\n            error_count += 1\n            processed_list.append(tid)\n            progress['processed'] = processed_list\n            save_progress(progress)\n            continue\n        \n        size_mb = os.path.getsize(audio_file) / 1024 / 1024\n        print(f\"  Downloaded: {size_mb:.1f}MB\")\n        \n        # Transcribe\n        print(f\"  Transcribing... (this takes a few mins)\")\n        transcript = transcribe_audio(audio_file, tid)\n        \n        if not transcript or len(transcript) < 20:\n            print(f\"  Transcription failed\")\n            os.remove(audio_file)\n            error_count += 1\n            processed_list.append(tid)\n            progress['processed'] = processed_list\n            save_progress(progress)\n            continue\n        \n        # Summarize\n        word_count = len(transcript.split())\n        summary = summarize_transcript(transcript, word_count)\n        \n        # Get original tweet text\n        with open(LIKES_FILE) as f:\n            likes = json.load(f)\n        orig_text = next((t.get('text','') for t in likes if t.get('id') == tid), '')\n        \n        # Save\n        out_data = {\n            'tweet_id': tid,\n            'video_url': tweet_url,\n            'original_text': orig_text,\n            'transcript': transcript,\n            'summary': summary,\n            'word_count': word_count,\n            'media_key': media_info.get('media_key'),\n            'duration_ms': media_info.get('duration_ms'),\n            'transcribed_at': datetime.now().strftime('%Y-%m-%d')\n        }\n        \n        out_file = os.path.join(TRANSCRIPT_DIR, f\"{tid}.json\")\n        with open(out_file, 'w', errors='ignore') as f:\n            json.dump(out_data, f, indent=2, ensure_ascii=False)\n        \n        print(f\"  ✓ {word_count} words → {out_file}\")\n        \n        # Delete video to save space\n        os.remove(audio_file)\n        txt_file = audio_file.replace('.m4a', '.txt')\n        if os.path.exists(txt_file):\n            os.remove(txt_file)\n        \n        processed_list.append(tid)\n        progress['processed'] = processed_list\n        progress['last_tweet_id'] = tid\n        save_progress(progress)\n        mark_processed(tid)\n        \n        transcribed_count += 1\n        \n        # Be nice to API\n        time.sleep(1)\n    \n    print(f\"\\n{'='*50}\")\n    print(f\"Done! Transcribed: {transcribed_count}, Errors: {error_count}\")\n    print(f\"Total processed: {len(processed_list)}\")\n\nif __name__ == '__main__':\n    main()","path":"/Users/bobbygalletta/.openclaw/workspace-x/x-scripts/transcribe-likes-videos.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":492,"output":2414,"cacheRead":81600,"cacheWrite":0,"totalTokens":84506,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777781407934,"responseId":"0645fda0fbcfdada04555e01a64d68c5"}}
