{"type":"message","id":"fcc9e5de","parentId":"6eb05bd4","timestamp":"2026-05-03T05:05:45.619Z","message":{"role":"toolResult","toolCallId":"call_function_5pgjin59wn3z_1","toolName":"exec","content":[{"type":"text","text":"Authentication management\n\nUsage:\n  xurl auth [command]\n\nAvailable Commands:\n  app         Configure app-auth (bearer token)\n  apps        Manage registered X API apps\n  clear       Clear authentication tokens\n  default     Set default app and/or user (interactive or by argument)\n  oauth1      Configure OAuth1 authentication\n  oauth2      Configure OAuth2 authentication\n  status      Show authentication status\n\nFlags:\n  -h, --help   help for auth\n\nGlobal Flags:\n      --app string   Use a specific registered app (overrides default)\n\nUse \"xurl auth [command] --help\" for more information about a command."}],"details":{"status":"completed","exitCode":0,"durationMs":41,"aggregated":"Authentication management\n\nUsage:\n  xurl auth [command]\n\nAvailable Commands:\n  app         Configure app-auth (bearer token)\n  apps        Manage registered X API apps\n  clear       Clear authentication tokens\n  default     Set default app and/or user (interactive or by argument)\n  oauth1      Configure OAuth1 authentication\n  oauth2      Configure OAuth2 authentication\n  status      Show authentication status\n\nFlags:\n  -h, --help   help for auth\n\nGlobal Flags:\n      --app string   Use a specific registered app (overrides default)\n\nUse \"xurl auth [command] --help\" for more information about a command.","cwd":"/Users/bobbygalletta/.openclaw/workspace-x"},"isError":false,"timestamp":1777784745619}}
