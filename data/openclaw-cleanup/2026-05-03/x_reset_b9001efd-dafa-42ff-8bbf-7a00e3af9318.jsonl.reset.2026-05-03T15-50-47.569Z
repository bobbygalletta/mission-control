{"type":"message","id":"1290694a","parentId":"5a54e236","timestamp":"2026-05-03T04:08:52.615Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the analyze script to also check for videos in the likes and transcribe them. Actually, let me first test the transcription script with one video to make sure it works. But I need a video URL from the likes first.\n\nLet me write a more comprehensive script that:\n1. Goes through all likes\n2. Finds ones with videos\n3. Downloads and transcribes them\n4. Saves the transcript + summary\n5. Deletes the video\n6. Updates a checkpoint so we know which ones we've already done\n\nLet me think about this more carefully. The likes we collected don't contain video URLs - we got the tweet text and metadata but not the expanded media URLs. I need to check the actual media entities in the tweets. \n\nLooking at the earlier tweet data, I can see the tweets do contain media information with expanded URLs. Let me build a script that extracts videos from the likes we've already collected and processes them. The transcript files would be stored locally by tweet ID, and for future daily checks, we'd pull new liked tweets and scan their media for videos to process.\n","thinkingSignature":"6c419e392e9c8542c3b6300d1e1eef0c486cb7c606319ceda039776c64e2f820"},{"type":"toolCall","id":"call_function_jpohi9gx5dur_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"Process all liked tweets that contain videos — download, transcribe, save, cleanup.\"\"\"\n\nimport json\nimport os\nimport subprocess\nimport sys\n\nDATA_DIR = os.path.expanduser(\"~/.openclaw/workspace-x/x-data\")\nLIKES_FILE = os.path.join(DATA_DIR, \"all-likes.json\")\nTRANSCRIPT_DIR = os.path.join(DATA_DIR, \"video-transcripts\")\nPROCESSED_FILE = os.path.join(DATA_DIR, \"transcribed-videos.json\")\n\nos.makedirs(TRANSCRIPT_DIR, exist_ok=True)\n\n# Load likes\nwith open(LIKES_FILE) as f:\n    likes = json.load(f)\n\n# Load already-processed list\nprocessed = set()\nif os.path.exists(PROCESSED_FILE):\n    with open(PROCESSED_FILE) as f:\n        processed = set(json.load(f))\n\nprint(f\"Total likes: {len(likes)}\")\nprint(f\"Already transcribed: {len(processed)}\")\n\n# Find tweets with videos\nvideo_tweets = []\nfor tweet in likes:\n    tid = tweet.get('id','')\n    if tid in processed:\n        continue\n    entities = tweet.get('entities', {})\n    media = entities.get('media', [])\n    for m in media:\n        if m.get('type') == 'video' or m.get('type') == 'animated_gif':\n            video_url = m.get('video_info', {}).get('variants', [{}])[0].get('url', '')\n            if video_url:\n                video_tweets.append({\n                    'tweet_id': tid,\n                    'url': video_url,\n                    'text': tweet.get('text', '')[:100]\n                })\n                break\n\nprint(f\"Tweets with videos to transcribe: {len(video_tweets)}\")\n\nif not video_tweets:\n    print(\"No new videos to transcribe.\")\n    sys.exit(0)\n\n# Process each video\ntranscribed = []\nerrors = 0\n\nfor i, item in enumerate(video_tweets):\n    tid = item['tweet_id']\n    url = item['url']\n    \n    print(f\"\\n[{i+1}/{len(video_tweets)}] Processing {tid}\")\n    print(f\"  Text: {item['text'][:60]}...\")\n    \n    out_file = os.path.join(TRANSCRIPT_DIR, f\"{tid}.json\")\n    temp_audio = f\"/tmp/x-video-{tid}.m4a\"\n    \n    # Download audio\n    dl_cmd = [\n        'yt-dlp', '-x', '--audio-format', 'm4a',\n        '--audio-quality', '0', '-o', temp_audio, url\n    ]\n    result = subprocess.run(dl_cmd, capture_output=True, timeout=60)\n    \n    if result.returncode != 0 or not os.path.exists(temp_audio):\n        print(f\"  ERROR: Download failed\")\n        errors += 1\n        continue\n    \n    size = os.path.getsize(temp_audio)\n    if size < 1000:\n        print(f\"  ERROR: File too small ({size} bytes)\")\n        os.remove(temp_audio)\n        errors += 1\n        continue\n    \n    print(f\"  Downloaded: {size/1024:.0f}KB — transcribing...\")\n    \n    # Transcribe\n    temp_txt = f\"/tmp/x-video-{tid}.txt\"\n    tr_cmd = [\n        'whisper', temp_audio,\n        '--model', 'medium',\n        '--output_dir', '/tmp',\n        '--output_format', 'txt',\n        '--language', 'English',\n        '--verbose', 'False'\n    ]\n    result = subprocess.run(tr_cmd, capture_output=True, timeout=300)\n    \n    # Try to find the output\n    for ext in ['.txt', '.json']:\n        candidate = f\"/tmp/x-video-{tid}{ext}\"\n        if os.path.exists(candidate):\n            temp_txt = candidate\n            break\n    \n    if not os.path.exists(temp_txt):\n        print(f\"  ERROR: Transcription failed\")\n        os.remove(temp_audio)\n        errors += 1\n        continue\n    \n    with open(temp_txt, 'r', errors='ignore') as f:\n        transcript = f.read().strip()\n    \n    if len(transcript) < 20:\n        print(f\"  ERROR: Transcript too short\")\n        os.remove(temp_audio)\n        if temp_txt != f\"/tmp/x-video-{tid}.txt\":\n            os.remove(temp_txt)\n        errors += 1\n        continue\n    \n    words = len(transcript.split())\n    \n    # Summary\n    summary = transcript[:400].strip()\n    if len(transcript) > 400:\n        summary += '...'\n    summary += f\"\\n\\n[{words} words]\"\n    \n    # Save\n    data = {\n        'tweet_id': tid,\n        'video_url': url,\n        'original_text': item['text'],\n        'transcript': transcript,\n        'summary': summary,\n        'word_count': words,\n        'transcribed_at': '2026-05-03'\n    }\n    \n    with open(out_file, 'w', errors='ignore') as f:\n        json.dump(data, f, indent=2, ensure_ascii=False)\n    \n    print(f\"  ✓ Saved {words} words → {out_file}\")\n    \n    # Cleanup\n    os.remove(temp_audio)\n    if os.path.exists(temp_txt):\n        os.remove(temp_txt)\n    if os.path.exists(f\"/tmp/x-video-{tid}.srt\"):\n        os.remove(f\"/tmp/x-video-{tid}.srt\")\n    \n    transcribed.append(tid)\n\n# Update processed list\nprocessed_list = list(processed) + transcribed\nwith open(PROCESSED_FILE, 'w') as f:\n    json.dump(processed_list, f)\n\nprint(f\"\\n{'='*50}\")\nprint(f\"Done! Transcribed: {len(transcribed)}, Errors: {errors}\")\nprint(f\"Total transcribed: {len(processed_list)}\")\nif transcribed:\n    print(\"\\nSample:\")\n    sample_file = os.path.join(TRANSCRIPT_DIR, f\"{transcribed[0]}.json\")\n    with open(sample_file) as f:\n        d = json.load(f)\n    print(f\"  {d['summary'][:200]}\")","path":"/Users/bobbygalletta/.openclaw/workspace-x/x-scripts/transcribe-all-likes.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":1042,"output":1576,"cacheRead":76800,"cacheWrite":0,"totalTokens":79418,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777781309537,"responseId":"0645fd3d7f6c74c88ebb28d3e98cc65d"}}
