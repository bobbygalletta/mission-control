{"type":"message","id":"0923a8c2","parentId":"fdc57448","timestamp":"2026-05-03T04:18:35.088Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"yt-dlp can download X videos just fine! The issue is that my detection method - looking for `/video/` in the tweet text - is unreliable because the API data doesn't always contain the full expanded URLs.\n\nNow let me look at what tweets we actually have with videos. Since I already downloaded the likes, and I saw those posts on the browser earlier with videos, the issue is that the API data isn't giving me the full URLs in the text field.\n\nThe solution is: for any tweet that might have a video, I should just try to download it with yt-dlp and see if it works. If yt-dlp finds a video, it will download it. If not, it won't.\n\n\nNow I'll update the script to attempt downloads for all the video tweets I've identified, using yt-dlp as the detection mechanism itself.\n","thinkingSignature":"0d2ee7850fda2cd33dffba8b942710b8eb619326122ae5a3a1ac1bca1cca95e7"},{"type":"text","text":"\n\nyt-dlp works perfectly for X videos. The issue was my detection method — the API data doesn't always show `/video/` in the tweet text. Let me fix the scan script to just try downloading any tweet that looks like it might have a video.\n"},{"type":"toolCall","id":"call_function_kg8ay3187g98_1","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nFull scan of all likes — try to download and transcribe any videos.\nUses yt-dlp to both detect AND download videos from X posts.\n\"\"\"\nimport json\nimport os\nimport subprocess\nimport time\nfrom datetime import datetime\n\nHOME = os.path.expanduser(\"~\")\nDATA_DIR = f\"{HOME}/.openclaw/workspace-x/x-data\"\nTRANSCRIPT_DIR = f\"{DATA_DIR}/video-transcripts\"\nCHECKPOINT_FILE = f\"{DATA_DIR}/x-scan-checkpoint.json\"\nPROCESSED_LIKES_FILE = f\"{DATA_DIR}/processed-like-ids.json\"\nOUTPUT_FILE = f\"{DATA_DIR}/x-daily-output.json\"\n\nos.makedirs(TRANSCRIPT_DIR, exist_ok=True)\n\ndef load_checkpoint():\n    if os.path.exists(CHECKPOINT_FILE):\n        with open(CHECKPOINT_FILE) as f:\n            return json.load(f)\n    return {\"last_like_id\": None, \"last_scan_date\": None}\n\ndef save_checkpoint(cp):\n    with open(CHECKPOINT_FILE, 'w') as f:\n        json.dump(cp, f, indent=2)\n\ndef fetch_all_likes():\n    all_likes = []\n    token = \"\"\n    while True:\n        if token:\n            cmd = ['xurl', f'/2/users/1959983838211260416/liked_tweets?pagination_token={token}']\n        else:\n            cmd = ['xurl', '/2/users/1959983838211260416/liked_tweets']\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=20)\n        if result.returncode != 0:\n            break\n        try:\n            d = json.loads(result.stdout)\n        except:\n            break\n        data = d.get('data', [])\n        if not data:\n            break\n        all_likes.extend(data)\n        token = d.get('meta', {}).get('next_token', '')\n        if not token:\n            break\n    return all_likes\n\ndef might_have_video(tweet):\n    \"\"\"Heuristic: tweet has an x.com link (could be video)\"\"\"\n    text = tweet.get('text', '')\n    return 'x.com/' in text and ('/status/' in text or 't.co' in text)\n\ndef try_download_video(tid, original_text):\n    \"\"\"Try to download video. Returns True if video found and downloaded.\"\"\"\n    transcript_file = f\"{TRANSCRIPT_DIR}/{tid}.json\"\n    if os.path.exists(transcript_file):\n        return 'already_done', None\n    \n    temp_audio = f\"/tmp/x-full-{tid}.m4a\"\n    \n    # Remove old file if exists\n    if os.path.exists(temp_audio):\n        os.remove(temp_audio)\n    \n    # Try download with yt-dlp (extract audio only)\n    dl = subprocess.run([\n        'yt-dlp', '-x', '--audio-format', 'm4a', '--audio-quality', '0',\n        '-o', temp_audio, '--quiet', '--no-playlist', '--no-warnings',\n        f'https://x.com/i/status/{tid}'\n    ], capture_output=True, text=True, timeout=60)\n    \n    if dl.returncode != 0:\n        # Check if it's a video type error (means video existed but download failed)\n        stderr = dl.stderr.lower()\n        if 'video' in stderr or 'this media' in stderr or 'is not available' in stderr:\n            return 'no_video', None\n        return 'error', dl.stderr[:100]\n    \n    if not os.path.exists(temp_audio):\n        return 'no_file', None\n    \n    size = os.path.getsize(temp_audio)\n    if size < 5000:\n        os.remove(temp_audio)\n        return 'file_too_small', None\n    \n    return 'downloaded', temp_audio\n\ndef transcribe(temp_audio, tid):\n    txt_file = f\"/tmp/x-full-{tid}.txt\"\n    \n    tr = subprocess.run([\n        'whisper', temp_audio,\n        '--model', 'medium',\n        '--output_dir', '/tmp',\n        '--output_format', 'txt',\n        '--language', 'English',\n        '--verbose', 'False'\n    ], capture_output=True, timeout=300)\n    \n    # Find the output file\n    for candidate in [txt_file, temp_audio.replace('.m4a', '.txt')]:\n        if os.path.exists(candidate):\n            with open(candidate, 'r', errors='ignore') as f:\n                transcript = f.read().strip()\n            os.remove(candidate)\n            return transcript\n    \n    return None\n\ndef main():\n    print(f\"\\n=== Full X Likes Video Scan: {datetime.now().strftime('%Y-%m-%d %H:%M')} ===\\n\")\n    \n    all_likes = fetch_all_likes()\n    if not all_likes:\n        print(\"No likes fetched\")\n        return\n    \n    print(f\"Total likes: {len(all_likes)}\")\n    \n    # Save all likes\n    with open(f\"{DATA_DIR}/all-likes.json\", 'w') as f:\n        json.dump(all_likes, f, indent=2)\n    \n    with open(PROCESSED_LIKES_FILE, 'w') as f:\n        json.dump([t['id'] for t in all_likes], f)\n    \n    # Find candidates that might have videos\n    candidates = [t for t in all_likes if might_have_video(t)]\n    print(f\"Potential video candidates: {len(candidates)}\")\n    \n    # Set checkpoint\n    cp = load_checkpoint()\n    cp['last_like_id'] = all_likes[0]['id']\n    cp['last_scan_date'] = datetime.now().strftime('%Y-%m-%d')\n    save_checkpoint(cp)\n    \n    if not candidates:\n        print(\"No video candidates found\")\n        return\n    \n    # Process each candidate\n    results = []\n    stats = {'already_done': 0, 'no_video': 0, 'downloaded': 0, 'errors': 0}\n    \n    print(f\"\\nScanning {len(candidates)} candidates for videos...\\n\")\n    \n    for i, tweet in enumerate(candidates):\n        tid = tweet['id']\n        original_text = tweet['text'][:100]\n        \n        print(f\"[{i+1}/{len(candidates)}] {tid}...\", end=\" \", flush=True)\n        \n        status, data = try_download_video(tid, original_text)\n        \n        if status == 'already_done':\n            stats['already_done'] += 1\n            print(\"already transcribed\")\n            # Load existing summary\n            with open(f\"{TRANSCRIPT_DIR}/{tid}.json\") as f:\n                d = json.load(f)\n            results.append({'tid': tid, 'summary': d.get('summary',''), 'text': original_text})\n        \n        elif status == 'no_video' or status == 'no_file':\n            stats['no_video'] += 1\n            print(\"no video\")\n        \n        elif status == 'downloaded':\n            print(f\"downloading... \", end=\"\", flush=True)\n            transcript = transcribe(data, tid)\n            os.remove(data)  # Delete audio file\n            \n            if transcript and len(transcript) >= 20:\n                words = len(transcript.split())\n                summary = transcript[:400].strip()\n                if len(transcript) > 400:\n                    summary += '...'\n                summary += f\"\\n\\n[{words} words]\"\n                \n                with open(f\"{TRANSCRIPT_DIR}/{tid}.json\", 'w') as f:\n                    json.dump({\n                        'tweet_id': tid,\n                        'video_url': f'https://x.com/i/status/{tid}',\n                        'original_text': original_text,\n                        'transcript': transcript,\n                        'summary': summary,\n                        'word_count': words,\n                        'transcribed_at': datetime.now().strftime('%Y-%m-%d')\n                    }, f, indent=2, ensure_ascii=False)\n                \n                stats['downloaded'] += 1\n                results.append({'tid': tid, 'summary': summary, 'text': original_text})\n                print(f\"✓ {words} words\")\n            else:\n                stats['errors'] += 1\n                print(f\"transcription failed\")\n        \n        else:\n            stats['errors'] += 1\n            print(f\"error: {status}\")\n        \n        time.sleep(0.5)\n    \n    # Build output\n    output = {\n        'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M'),\n        'total_likes': len(all_likes),\n        'candidates_checked': len(candidates),\n        'new_videos_transcribed': stats['downloaded'],\n        'already_transcribed': stats['already_done'],\n        'no_video_found': stats['no_video'],\n        'errors': stats['errors'],\n        'new_videos': results,\n        'has_new': len(results) > 0\n    }\n    \n    with open(OUTPUT_FILE, 'w') as f:\n        json.dump(output, f, indent=2)\n    \n    print(f\"\\n{'='*50}\")\n    print(f\"Done!\")\n    print(f\"  Candidates checked: {len(candidates)}\")\n    print(f\"  New videos transcribed: {stats['downloaded']}\")\n    print(f\"  Already done: {stats['already_done']}\")\n    print(f\"  No video: {stats['no_video']}\")\n    print(f\"  Errors: {stats['errors']}\")\n    print(f\"\\nResults: {OUTPUT_FILE}\")\n    \n    if results:\n        print(f\"\\nTranscribed videos:\")\n        for r in results:\n            print(f\"  - {r['summary'][:80]}...\")\n\nif __name__ == '__main__':\n    main()","path":"/Users/bobbygalletta/.openclaw/workspace-x/x-scripts/full-likes-scan.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":5572,"output":2306,"cacheRead":99456,"cacheWrite":0,"totalTokens":107334,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1777781884302,"responseId":"0645ff7c3c0e70f7ee29b59de8561ebf"}}
