{"type":"message","id":"4e00eb4e","parentId":"c925ac2f","timestamp":"2026-03-23T23:54:53.322Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the AgentCard component.","thinkingSignature":"da0116afde14305f01915339247a183032f902165613791b06836832e4d8ac7d"},{"type":"toolCall","id":"call_function_z30pzkidxfdg_1","name":"write","arguments":{"content":"import React from 'react';\nimport { AgentState } from '../lib/types';\nimport { StatusBadge } from './StatusBadge';\nimport { Clock } from 'lucide-react';\n\ninterface AgentCardProps {\n  state: AgentState;\n  index: number;\n  onClick: () => void;\n}\n\nfunction formatLastActive(date: Date | null): string {\n  if (!date) return 'Never';\n  const now = Date.now();\n  const diff = now - date.getTime();\n\n  if (diff < 60_000) return 'Just now';\n  if (diff < 3_600_000) return `${Math.floor(diff / 60_000)}m ago`;\n  if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)}h ago`;\n  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });\n}\n\nexport const AgentCard: React.FC<AgentCardProps> = ({ state, index, onClick }) => {\n  const { agent, status, lastActive } = state;\n\n  return (\n    <button\n      onClick={onClick}\n      className=\"glass-panel-hover text-left w-full group\"\n      style={{\n        animationDelay: `${index * 60}ms`,\n        animation: 'fade-in-up 0.35s ease-out forwards',\n        opacity: 0,\n      }}\n    >\n      <div className=\"p-5\">\n        {/* Top row: Avatar + Name/Role */}\n        <div className=\"flex items-start gap-4\">\n          {/* Avatar */}\n          <div\n            className={`w-12 h-12 rounded-2xl flex items-center justify-center text-2xl flex-shrink-0 transition-all duration-200 ${\n              status === 'online'\n                ? 'bg-green-400/10 ring-1 ring-green-400/20'\n                : status === 'busy'\n                ? 'bg-yellow-400/10 ring-1 ring-yellow-400/20'\n                : status === 'error'\n                ? 'bg-red-400/10 ring-1 ring-red-400/20'\n                : 'bg-slate-800/50'\n            }`}\n          >\n            {agent.emoji}\n          </div>\n\n          {/* Name + Role */}\n          <div className=\"flex-1 min-w-0\">\n            <h3 className=\"font-semibold text-slate-100 text-base leading-tight truncate\">\n              {agent.name}\n            </h3>\n            <p className=\"text-slate-500 text-xs mt-0.5 truncate\">{agent.role}</p>\n          </div>\n\n          {/* Chevron */}\n          <div className=\"flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity duration-200\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" className=\"text-slate-400 mt-1\">\n              <path d=\"M6 4l4 4-4 4\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\"/>\n            </svg>\n          </div>\n        </div>\n\n        {/* Bottom row: Status + Last Active */}\n        <div className=\"flex items-center justify-between mt-4 pt-3 border-t border-white/5\">\n          <StatusBadge status={status} />\n          <div className=\"flex items-center gap-1 text-slate-600\">\n            <Clock className=\"w-3 h-3\" />\n            <span className=\"font-mono text-xs text-slate-500\">\n              {formatLastActive(lastActive)}\n            </span>\n          </div>\n        </div>\n      </div>\n    </button>\n  );\n};\n","file_path":"/Users/bobbygalletta/agent-mission-control/src/components/AgentCard.tsx"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":28463,"output":866,"cacheRead":15940,"cacheWrite":0,"totalTokens":45269,"cost":{"input":0.0085389,"output":0.0010391999999999999,"cacheRead":0.0009563999999999999,"cacheWrite":0,"total":0.0105345}},"stopReason":"toolUse","timestamp":1774310080250,"responseId":"061105c07859b38c4612de8449138b64"}}
