{"type":"message","id":"23bf74aa","parentId":"0a491d69","timestamp":"2026-03-23T23:55:15.275Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the ComposeModal component.","thinkingSignature":"de39335045bcd23c121f312c3a0cb18df1043d5a1be8f55e1c017911e648e29e"},{"type":"toolCall","id":"call_function_ugdqsekxk2fc_1","name":"write","arguments":{"content":"import React, { useState, useEffect, useRef, useCallback } from 'react';\nimport { X, Send, Loader2 } from 'lucide-react';\nimport { Agent } from '../lib/types';\nimport { sendChatMessage } from '../lib/gateway';\n\ninterface ComposeModalProps {\n  agent: Agent | null;\n  isOpen: boolean;\n  onClose: () => void;\n  onSent: (text: string) => void;\n}\n\nexport const ComposeModal: React.FC<ComposeModalProps> = ({\n  agent,\n  isOpen,\n  onClose,\n  onSent,\n}) => {\n  const [message, setMessage] = useState('');\n  const [status, setStatus] = useState<'idle' | 'sending' | 'error'>('idle');\n  const [errorMsg, setErrorMsg] = useState('');\n  const textareaRef = useRef<HTMLTextAreaElement>(null);\n\n  useEffect(() => {\n    if (isOpen) {\n      setMessage('');\n      setStatus('idle');\n      setErrorMsg('');\n      setTimeout(() => textareaRef.current?.focus(), 100);\n    }\n  }, [isOpen]);\n\n  const handleKeyDown = useCallback(\n    (e: React.KeyboardEvent<HTMLTextAreaElement>) => {\n      if (e.key === 'Escape') {\n        onClose();\n        return;\n      }\n      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {\n        e.preventDefault();\n        handleSend();\n      }\n    },\n    [message, status]\n  );\n\n  const handleSend = async () => {\n    if (!message.trim() || status === 'sending' || !agent) return;\n\n    setStatus('sending');\n    setErrorMsg('');\n\n    try {\n      await sendChatMessage(agent.id, message.trim());\n      setStatus('idle');\n      onSent(`Message sent to ${agent.name}`);\n      onClose();\n    } catch (err) {\n      setStatus('error');\n      setErrorMsg(err instanceof Error ? err.message : 'Failed to send message');\n    }\n  };\n\n  if (!isOpen || !agent) return null;\n\n  return (\n    <div\n      className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\n      onClick={(e) => e.target === e.currentTarget && onClose()}\n    >\n      {/* Backdrop */}\n      <div className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" />\n\n      {/* Modal */}\n      <div\n        className=\"relative glass-modal w-full max-w-md animate-modal-in\"\n        style={{ animation: 'modal-in 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards' }}\n      >\n        {/* Header */}\n        <div className=\"flex items-center gap-3 p-5 border-b border-white/5\">\n          <div\n            className=\"w-10 h-10 rounded-xl flex items-center justify-center text-xl bg-accent-indigo/10 ring-1 ring-accent-indigo/20\"\n          >\n            {agent.emoji}\n          </div>\n          <div className=\"flex-1\">\n            <h2 className=\"font-semibold text-slate-100\">Message {agent.name}</h2>\n            <p className=\"text-xs text-slate-500\">{agent.role}</p>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/5 transition-colors\"\n          >\n            <X className=\"w-4 h-4\" />\n          </button>\n        </div>\n\n        {/* Body */}\n        <div className=\"p-5 space-y-4\">\n          <div>\n            <textarea\n              ref={textareaRef}\n              value={message}\n              onChange={(e) => setMessage(e.target.value)}\n              onKeyDown={handleKeyDown}\n              placeholder={`Send a message to ${agent.name}…`}\n              rows={4}\n              className=\"input-glass\"\n              disabled={status === 'sending'}\n            />\n            <p className=\"text-xs text-slate-600 mt-1.5 text-right\">\n              {navigator.platform.includes('Mac') ? '⌘' : 'Ctrl'}+Enter to send\n            </p>\n          </div>\n\n          {status === 'error' && (\n            <div className=\"px-3 py-2 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-xs\">\n              {errorMsg}\n            </div>\n          )}\n        </div>\n\n        {/* Footer */}\n        <div className=\"flex items-center gap-3 p-5 border-t border-white/5\">\n          <button onClick={onClose} className=\"btn-ghost flex-1\">\n            Cancel\n          </button>\n          <button\n            onClick={handleSend}\n            disabled={!message.trim() || status === 'sending'}\n            className=\"btn-primary flex-1 flex items-center justify-center gap-2\"\n          >\n            {status === 'sending' ? (\n              <>\n                <Loader2 className=\"w-4 h-4 animate-spin\" />\n                Sending…\n              </>\n            ) : (\n              <>\n                <Send className=\"w-4 h-4\" />\n                Send\n              </>\n            )}\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n};\n","file_path":"/Users/bobbygalletta/agent-mission-control/src/components/ComposeModal.tsx"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":29739,"output":1236,"cacheRead":15940,"cacheWrite":0,"totalTokens":46915,"cost":{"input":0.0089217,"output":0.0014831999999999998,"cacheRead":0.0009563999999999999,"cacheWrite":0,"total":0.0113613}},"stopReason":"toolUse","timestamp":1774310098841,"responseId":"061105d22ca294dea99628ff857b423f"}}
