{"type":"message","id":"9f228f75","parentId":"e99e273e","timestamp":"2026-03-23T23:54:02.366Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the gateway client.","thinkingSignature":"d994ed287cde19938efc7aadb14a911f46c62895ab2915d77eaf38707678fd92"},{"type":"toolCall","id":"call_function_ev9rfly7opk8_1","name":"write","arguments":{"content":"import { GATEWAY_URL, GATEWAY_TOKEN } from './agents';\nimport { AgentStatus, GatewayPresence } from './types';\n\nexport interface SessionsListResult {\n  sessions: Array<{\n    sessionKey: string;\n    agentId: string;\n    updatedAt: number;\n    status?: string;\n  }>;\n}\n\nfunction getHeaders(): HeadersInit {\n  const headers: HeadersInit = { 'Content-Type': 'application/json' };\n  if (GATEWAY_TOKEN) {\n    headers['Authorization'] = `Bearer ${GATEWAY_TOKEN}`;\n  }\n  return headers;\n}\n\nexport async function invokeTool(tool: string, args: Record<string, unknown> = {}): Promise<unknown> {\n  const res = await fetch(`${GATEWAY_URL}/tools/invoke`, {\n    method: 'POST',\n    headers: getHeaders(),\n    body: JSON.stringify({ tool, args }),\n  });\n\n  if (!res.ok) {\n    const text = await res.text().catch(() => 'Unknown error');\n    throw new Error(`Gateway error ${res.status}: ${text}`);\n  }\n\n  const data = await res.json();\n  if (!data.ok) {\n    throw new Error(data.error?.message || 'Tool invocation failed');\n  }\n  return data.result;\n}\n\nexport async function listSessions(): Promise<SessionsListResult> {\n  try {\n    const result = await invokeTool('sessions_list', {}) as SessionsListResult;\n    return result;\n  } catch {\n    return { sessions: [] };\n  }\n}\n\nexport async function sendChatMessage(agentId: string, message: string): Promise<void> {\n  await invokeTool('message', {\n    action: 'send',\n    channel: 'telegram',\n    target: '8212808444',\n    message,\n  });\n}\n\nexport async function checkGatewayHealth(): Promise<boolean> {\n  try {\n    const res = await fetch(`${GATEWAY_URL}/health`, {\n      method: 'GET',\n      headers: getHeaders(),\n    });\n    return res.ok;\n  } catch {\n    return false;\n  }\n}\n\n// Derive agent status from sessions data\nexport function deriveAgentStatus(\n  agentId: string,\n  sessions: SessionsListResult['sessions']\n): AgentStatus {\n  const agentSessions = sessions.filter(\n    (s) => s.agentId === agentId || s.sessionKey?.includes(agentId)\n  );\n\n  if (agentSessions.length === 0) return 'offline';\n\n  // Check if any session was recently active (within 30s)\n  const now = Date.now();\n  const recent = agentSessions.filter((s) => now - s.updatedAt < 30_000);\n\n  if (recent.length > 0) return 'online';\n\n  // Check status field if present\n  const hasActive = agentSessions.some(\n    (s) => s.status === 'running' || s.status === 'active'\n  );\n  if (hasActive) return 'busy';\n\n  return 'offline';\n}\n\n// WebSocket presence client\nexport type PresenceHandler = (presences: GatewayPresence[]) => void;\nexport type ConnectionHandler = (connected: boolean) => void;\n\nlet ws: WebSocket | null = null;\nlet reconnectTimer: ReturnType<typeof setTimeout> | null = null;\nlet currentPresenceHandler: PresenceHandler | null = null;\nlet currentConnHandler: ConnectionHandler | null = null;\n\nfunction buildWsUrl(): string {\n  const url = GATEWAY_URL.replace('http://', 'ws://').replace('https://', 'wss://');\n  return `${url}/ws`;\n}\n\nexport function connectPresence(\n  onPresence: PresenceHandler,\n  onConnection: ConnectionHandler\n): () => void {\n  currentPresenceHandler = onPresence;\n  currentConnHandler = onConnection;\n\n  function attemptConnect() {\n    try {\n      ws = new WebSocket(buildWsUrl());\n\n      ws.onopen = () => {\n        // Send connect handshake\n        const reqId = `req-${Date.now()}`;\n        ws!.send(JSON.stringify({\n          type: 'req',\n          id: reqId,\n          method: 'connect',\n          params: {\n            minProtocol: 3,\n            maxProtocol: 3,\n            client: { id: 'mission-control', version: '1.0.0', platform: 'web', mode: 'operator' },\n            role: 'operator',\n            scopes: ['operator.read', 'operator.write'],\n            caps: [],\n            commands: [],\n            permissions: {},\n            auth: GATEWAY_TOKEN ? { token: GATEWAY_TOKEN } : {},\n            locale: 'en-US',\n            userAgent: 'mission-control/1.0',\n          },\n        }));\n\n        // Subscribe to presence\n        const subId = `sub-${Date.now()}`;\n        ws!.send(JSON.stringify({\n          type: 'req',\n          id: subId,\n          method: 'presence.subscribe',\n          params: {},\n        }));\n      };\n\n      ws.onmessage = (event) => {\n        try {\n          const msg = JSON.parse(event.data as string);\n          if (msg.type === 'event' && (msg.event === 'presence' || msg.event === 'system-presence')) {\n            const presences: GatewayPresence[] = (msg.payload?.entries || msg.payload || []).map(\n              (entry: Record<string, unknown>) => ({\n                agentId: String(entry.agentId || entry.id || ''),\n                status: mapPresenceStatus(entry.status as string),\n                lastSeen: entry.lastSeen as number | undefined,\n                sessionKey: entry.sessionKey as string | undefined,\n              })\n            );\n            currentPresenceHandler?.(presences);\n          }\n          if (msg.type === 'res' && msg.ok && msg.payload?.type === 'hello-ok') {\n            currentConnHandler?.(true);\n          }\n        } catch {\n          // Ignore parse errors\n        }\n      };\n\n      ws.onclose = () => {\n        currentConnHandler?.(false);\n        // Reconnect after 5s\n        reconnectTimer = setTimeout(attemptConnect, 5000);\n      };\n\n      ws.onerror = () => {\n        ws?.close();\n      };\n    } catch {\n      currentConnHandler?.(false);\n      reconnectTimer = setTimeout(attemptConnect, 5000);\n    }\n  }\n\n  attemptConnect();\n\n  // Return cleanup function\n  return () => {\n    if (reconnectTimer) clearTimeout(reconnectTimer);\n    ws?.close();\n    ws = null;\n  };\n}\n\nfunction mapPresenceStatus(status?: string): AgentStatus {\n  if (!status) return 'offline';\n  const s = status.toLowerCase();\n  if (s === 'online' || s === 'active' || s === 'running') return 'online';\n  if (s === 'busy' || s === 'thinking' || s === 'streaming') return 'busy';\n  if (s === 'error' || s === 'failed') return 'error';\n  return 'offline';\n}\n","file_path":"/Users/bobbygalletta/agent-mission-control/src/lib/gateway.ts"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":24447,"output":1512,"cacheRead":15940,"cacheWrite":0,"totalTokens":41899,"cost":{"input":0.0073341,"output":0.0018143999999999999,"cacheRead":0.0009563999999999999,"cacheWrite":0,"total":0.0101049}},"stopReason":"toolUse","timestamp":1774310020956,"responseId":"06110585427b58def30994e1f6040c3e"}}
