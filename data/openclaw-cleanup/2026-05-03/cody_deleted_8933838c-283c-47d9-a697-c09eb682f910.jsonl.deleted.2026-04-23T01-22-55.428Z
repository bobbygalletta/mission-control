{"type":"message","id":"39a6faba","parentId":"c5b11d33","timestamp":"2026-03-23T23:54:34.701Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the Header component.","thinkingSignature":"ffc3c7a8bbd6f69b642a009f86fdb23364fbfb78842580d824f5b5ac2957a439"},{"type":"toolCall","id":"call_function_4yk7mo3jcbzq_1","name":"write","arguments":{"content":"import React from 'react';\nimport { Radio } from 'lucide-react';\nimport { ConnectionState } from '../lib/types';\nimport { useTime } from '../hooks/useTime';\n\ninterface HeaderProps {\n  connectionState: ConnectionState;\n}\n\nconst CONN_CONFIG: Record<ConnectionState, { color: string; label: string; dotClass: string }> = {\n  connected: { color: 'text-green-400', label: 'Gateway Live', dotClass: 'bg-green-400 shadow-glow-green' },\n  connecting: { color: 'text-yellow-400', label: 'Connecting…', dotClass: 'bg-yellow-400 animate-pulse' },\n  disconnected: { color: 'text-red-400', label: 'Gateway Offline', dotClass: 'bg-red-400' },\n};\n\nexport const Header: React.FC<HeaderProps> = ({ connectionState }) => {\n  const { timeStr, dateStr } = useTime();\n  const conn = CONN_CONFIG[connectionState];\n\n  return (\n    <header className=\"sticky top-0 z-40 glass-panel mb-8\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between\">\n        {/* Left: Title */}\n        <div className=\"flex items-center gap-3\">\n          <div className=\"relative\">\n            <div className=\"absolute inset-0 bg-accent-indigo/20 blur-xl rounded-full\" />\n            <h1 className=\"relative text-xl sm:text-2xl font-bold tracking-tight\">\n              <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-violet-400 to-indigo-400\">\n                Mission Control\n              </span>\n            </h1>\n          </div>\n        </div>\n\n        {/* Right: Time + Status */}\n        <div className=\"flex items-center gap-4 sm:gap-6\">\n          {/* Date/Time */}\n          <div className=\"text-right hidden sm:block\">\n            <div className=\"font-mono text-sm text-slate-200 tracking-wider\">{timeStr}</div>\n            <div className=\"font-mono text-xs text-slate-500\">{dateStr}</div>\n          </div>\n          <div className=\"sm:hidden\">\n            <div className=\"font-mono text-sm text-slate-200 tracking-wider\">{timeStr}</div>\n          </div>\n\n          {/* Connection Status */}\n          <div className=\"flex items-center gap-2 px-3 py-1.5 rounded-xl bg-white/5 border border-glass-border\">\n            <span className={`w-2 h-2 rounded-full ${conn.dotClass}`} />\n            <span className={`text-xs font-medium ${conn.color} hidden sm:inline`}>\n              {conn.label}\n            </span>\n            <Radio className={`w-3 h-3 ${conn.color} sm:hidden`} />\n          </div>\n        </div>\n      </div>\n    </header>\n  );\n};\n","file_path":"/Users/bobbygalletta/agent-mission-control/src/components/Header.tsx"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":27369,"output":706,"cacheRead":15940,"cacheWrite":0,"totalTokens":44015,"cost":{"input":0.0082107,"output":0.0008472,"cacheRead":0.0009563999999999999,"cacheWrite":0,"total":0.010014299999999999}},"stopReason":"toolUse","timestamp":1774310063443,"responseId":"061105aff6041c65922eeb08cdf1fb2c"}}
