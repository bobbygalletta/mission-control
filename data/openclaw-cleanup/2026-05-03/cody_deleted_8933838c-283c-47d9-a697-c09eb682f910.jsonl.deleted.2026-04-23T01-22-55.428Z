{"type":"message","id":"6efd4f6d","parentId":"bb6e7601","timestamp":"2026-03-23T23:54:17.122Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the useAgentStatus hook.","thinkingSignature":"52989ba756b9b9e57f6391a4a00e70302818807f32de8590a99476b108cce7b7"},{"type":"toolCall","id":"call_function_1vw8ec7eq29v_1","name":"write","arguments":{"content":"import { useState, useEffect, useCallback, useRef } from 'react';\nimport { AgentState, AgentStatus, ConnectionState } from '../lib/types';\nimport { AGENTS } from '../lib/agents';\nimport { listSessions, deriveAgentStatus, connectPresence } from '../lib/gateway';\n\nconst POLL_INTERVAL = 5000;\n\nfunction initAgentStates(): AgentState[] {\n  return AGENTS.map((agent) => ({\n    agent,\n    status: 'offline' as AgentStatus,\n    lastActive: null,\n  }));\n}\n\nexport function useAgentStatus() {\n  const [agentStates, setAgentStates] = useState<AgentState[]>(initAgentStates);\n  const [connectionState, setConnectionState] = useState<ConnectionState>('connecting');\n  const cleanupRef = useRef<(() => void) | null>(null);\n\n  const pollSessions = useCallback(async () => {\n    try {\n      const result = await listSessions();\n      setAgentStates((prev) =>\n        prev.map((as) => ({\n          ...as,\n          status: deriveAgentStatus(as.agent.id, result.sessions),\n          lastActive: findLastActive(as.agent.id, result.sessions),\n        }))\n      );\n      setConnectionState('connected');\n    } catch {\n      setConnectionState('disconnected');\n    }\n  }, []);\n\n  useEffect(() => {\n    // Initial poll\n    pollSessions();\n\n    // WebSocket presence connection\n    cleanupRef.current = connectPresence(\n      (presences) => {\n        setAgentStates((prev) =>\n          prev.map((as) => {\n            const presence = presences.find(\n              (p) => p.agentId === as.agent.id || p.sessionKey?.includes(as.agent.id)\n            );\n            if (!presence) return as;\n            return {\n              ...as,\n              status: presence.status,\n              lastActive: presence.lastSeen ? new Date(presence.lastSeen) : as.lastActive,\n            };\n          })\n        );\n        setConnectionState('connected');\n      },\n      (connected) => {\n        setConnectionState(connected ? 'connected' : 'connecting');\n      }\n    );\n\n    // Polling fallback\n    const pollInterval = setInterval(pollSessions, POLL_INTERVAL);\n\n    return () => {\n      cleanupRef.current?.();\n      clearInterval(pollInterval);\n    };\n  }, [pollSessions]);\n\n  return { agentStates, connectionState };\n}\n\nfunction findLastActive(\n  agentId: string,\n  sessions: Array<{ agentId: string; sessionKey: string; updatedAt: number }>\n): Date | null {\n  const matching = sessions.filter(\n    (s) => s.agentId === agentId || s.sessionKey?.includes(agentId)\n  );\n  if (matching.length === 0) return null;\n  const latest = Math.max(...matching.map((s) => s.updatedAt));\n  return new Date(latest);\n}\n","file_path":"/Users/bobbygalletta/agent-mission-control/src/hooks/useAgentStatus.ts"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":26260,"output":669,"cacheRead":15940,"cacheWrite":0,"totalTokens":42869,"cost":{"input":0.007878,"output":0.0008028,"cacheRead":0.0009563999999999999,"cacheWrite":0,"total":0.009637199999999999}},"stopReason":"toolUse","timestamp":1774310046848,"responseId":"0611059eb68d0e0b5bbcd56aa8418f18"}}
