ill at ~/.openclaw/skills/morning-brief/SKILL.md. Follow it EXACTLY. Deliver all 7 sections to Telegram chat 8212808444 ONE SECTION AT A TIME. Sections: Header, Weather, Bible Verse, Emails (yesterday+today via Gmail API), Calendar (7 days), Reminders, Suggestions. Do NOT include X/Twitter. Send each section separately via message tool.\",\n        \"model\": \"minimax-portal/MiniMax-M2.7\",\n        \"timeoutSeconds\": 3600\n      },\n      \"delivery\": {\n        \"mode\": \"announce\",\n        \"channel\": \"telegram\",\n        \"to\": \"8212808444\"\n      },\n      \"failureAlert\": {\n        \"after\": 3,\n        \"channel\": \"telegram\",\n        \"to\": \"8212808444\",\n        \"mode\": \"announce\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1777800600000,\n        \"lastRunAtMs\": 1777714200024,\n        \"lastRunStatus\": \"error\",\n        \"lastStatus\": \"error\",\n        \"lastDurationMs\": 144035,\n        \"lastDelivered\": true,\n        \"lastDeliveryStatus\": \"delivered\",\n        \"consecutiveErrors\": 1,\n        \"consecutiveSkipped\": 0,\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n        \"kind\": \"agentTurn\",\n        \"message\": \"Take your Flonase!\",\n        \"model\": \"minimax-portal/MiniMax-M2.7\",\n        \"timeoutSeconds\": 3600\n      },\n      \"delivery\": {\n        \"mode\": \"none\",\n        \"channel\": \"telegram\",\n        \"to\": \"8212808444\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1777813200000,\n        \"lastRunAtMs\": 1777726932887,\n        \"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 24047,\n        \"lastDeliveryStatus\": \"not-requested\",\n        \"consecutiveErrors\": 0,\n        \"consecutiveSkipped\": 0\n      },\n      \"updatedAtMs\": 1777726956934\n    },\n    {\n      \"id\": \"d0c43bd5-ad9a-4911-b0a9-81b9e4a1e30c\",\n      \"agentId\": \"finn\",\n      \"sessionKey\": \"agent:finn:telegram:dir