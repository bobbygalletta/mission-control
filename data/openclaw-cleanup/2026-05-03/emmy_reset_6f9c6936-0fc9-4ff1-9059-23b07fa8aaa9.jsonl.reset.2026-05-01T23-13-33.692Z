{"type":"message","id":"dd9fcac9","parentId":"a9b63bc1","timestamp":"2026-04-30T15:23:51.750Z","message":{"role":"toolResult","toolCallId":"call_function_njt0b5dpnafz_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nSmart Hourly Email Check - Only emails since last run\nUses Gmail API with proper timestamp filtering\n\"\"\"\n\nimport os\nimport json\nimport sys\nfrom datetime import datetime, timezone\nfrom google.oauth2.credentials import Credentials\nfrom googleapiclient.discovery import build\n\nSTATE_DIR = os.path.expanduser(\"~/.openclaw/workspace-emmy\")\nLAST_RUN_FILE = os.path.join(STATE_DIR, \"last_email_check.timestamp\")\nOUTPUT_FILE = os.path.join(STATE_DIR, \"last_email_summary.txt\")\nCREDS_PATH = os.path.expanduser(\"~/.config/gmail_oauth/credentials_full.json\")\n\n\ndef get_service():\n    creds_data = json.load(open(CREDS_PATH))\n    creds = Credentials(\n        token=creds_…n'],\n        refresh_token=creds_…n'],\n        client_id=creds_data['client_id'],\n        client_secret=creds_data['client_secret'],\n        token_uri='https://oauth2.googleapis.com/token',\n        scopes=['https://mail.google.com/']\n    )\n    return build('gmail', 'v1', credentials=creds)\n\n\ndef get_email_details(service, msg_id):\n    \"\"\"Get email metadata\"\"\"\n    msg = service.users().messages().get(\n        userId='me',\n        id=msg_id,\n        format='metadata',\n        metadataHeaders=['From', 'Subject', 'Date']\n    ).execute()\n    headers = {h['name']: h['value'] for h in msg['payload']['headers']}\n    internal_date = msg['internalDate']  # Unix timestamp in ms\n    return {\n        'id': msg_id,\n        'from': headers.get('From', 'Unknown'),\n        'subject': headers.get('Subject', 'No Subject'),\n        'date': headers.get('Date', 'Unknown'),\n        'internal_date': int(internal_date) // 1000,  # Convert to seconds\n        'labels': msg.get('labelIds', []),\n    }\n\n\ndef main():\n    current_time = int(datetime.now(timezone.utc).timestamp())\n    \n    # Read the OLD last_run timestamp BEFORE we overwrite it\n    old_last_run = None\n    if os.path.exists(LAST_RUN_FILE):\n        with open(LAST_RUN_FILE, 'r') as f:\n            old_last_run = int(f.read().strip())\n    \n    # NOW save the new timestamp (current time at START of this run)\n    with open(LAST_RUN_FILE, 'w') as f:\n        f.write(str(current_time))\n    \n    # Use the OLD timestamp to calculate cutoff (what we checked last time)\n    if old_last_run:\n        elapsed_minutes = (current_time - old_last_run) // 60\n        check_minutes = elapsed_minutes + 2  # 2 min buffer for clock drift\n        if check_minutes < 5:\n            check_minutes = 5\n        time_range_desc = f\"{check_minutes} minutes\"\n        # Cutoff is the OLD last run time (what we've already seen)\n        cutoff_time = old_last_run\n    else:\n        # First run - check last 65 minutes\n        check_minutes = 65\n        cutoff_time = current_time - (check_minutes * 60)\n        time_range_desc = \"65 minutes (first run)\"\n    \n    service = get_service()\n    \n    # Search for ALL emails in inbox (not just unread)\n    results = service.users().messages().list(\n        userId='me',\n        maxResults=100,\n        q='in:inbox'\n    ).execute()\n    \n    messages = results.get('messages', [])\n    \n    if not messages:\n        with open(OUTPUT_FILE, 'w') as f:\n            f.write(f\"NO_NEW_EMAILS\\n\")\n            f.write(f\"✅ All caught up - {datetime.now().strftime('%b %d, %Y @ %I:%M %p')}\\n\")\n            f.write(f\"Checked: {time_range_desc}\\n\")\n            f.write(f\"0 new emails\\n\")\n        print(f\"✅ No emails in inbox (last {time_range_desc})\")\n        return\n    \n    # Filter by timestamp - only emails AFTER our last check\n    new_emails = []\n    for m in messages:\n        detail = get_email_details(service, m['id'])\n        if detail['internal_date'] >= cutoff_time:\n            new_emails.append(detail)\n    \n    if not new_emails:\n        with open(OUTPUT_FILE, 'w') as f:\n            f.write(f\"NO_NEW_EMAILS\\n\")\n            f.write(f\"✅ All caught up - {datetime.now().strftime('%b %d, %Y @ %I:%M %p')}\\n\")\n            f.write(f\"Checked: {time_range_desc}\\n\")\n            f.write(f\"0 new emails\\n\")\n        print(f\"✅ No new emails (last {time_range_desc})\")\n        return\n    \n    # Write summary with marker for \"new emails found\"\n    with open(OUTPUT_FILE, 'w') as f:\n        f.write(f\"NEW_EMAILS_FOUND\\n\")\n        f.write(f\"📬 NEW EMAILS - {datetime.now().strftime('%b %d, %Y @ %I:%M %p')}\\n\")\n        f.write(f\"Checking last: {time_range_desc}\\n\")\n        f.write(f\"\\n\")\n        for email in new_emails:\n            dt = datetime.fromtimestamp(email['internal_date'], tz=timezone.utc).strftime('%Y-%m-%d %H:%M')\n            f.write(f\"{email['id']}  {dt}  {email['from'][:40]}  {email['subject'][:50]}\\n\")\n        f.write(f\"\\nTotal new: {len(new_emails)}\\n\")\n    \n    print(f\"📬 {len(new_emails)} new email(s) found (last {time_range_desc})\")\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1777562631750}}
