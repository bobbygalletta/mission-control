n\n💬 REPLY TO THIS and TT will set everything up based on what you decide.\n\nAlso — any new posts since last night?"},"delivery":{"mode":"announce","channel":"telegram","to":"8212808444"},"state":{"nextRunAtMs":1775134800000,"lastRunAtMs":1775048415492,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":27932,"lastDelivered":true,"lastDeliveryStatus":"delivered","consecutiveErrors":0}},{"id":"3c5c3265-22fa-47fc-ac2c-b40a0c9f987f","agentId":"main","sessionKey":"agent:main:telegram:cody:direct:8212808444","name":"Daily Meal Reminder","enabled":true,"createdAtMs":1774762850294,"updatedAtMs":1775048415492,"schedule":{"expr":"0 9 * * *","kind":"cron","tz":"America/New_York"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Run the meal check script and send the result as a Telegram message to Bobby:\n\nSCRIPT: /bin/bash $HOME/.openclaw/scripts/habits-meal-check.sh\n\nIf the script outputs text (not empty), use the message tool to send exactly that text to Telegram chat 8212808444. If the script outputs nothing, do nothing.","model":"local-tiny"},"delivery":{"mode":"none"},"state":{"nextRunAtMs":1775134800000,"lastRunAtMs":1775048400007,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":15485,"lastDelivered":false,"lastDeliveryStatus":"not-delivered","consecutiveErrors":0}},{"id":"75cad6ae-a385-4cb0-b759-18e20cbed04c","agentId":"finn","sessionKey":"agent:finn:telegram:direct:8212808444","name":"doordash-motivation-9am","enabled":true,"createdAtMs":1774766152264,"updatedAtMs":1775048503441,"schedule":{"kind":"cron","expr":"0 9 * * *","tz":"America/New_York"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Morning hustle Bobby 💪 $125 goal, let's go! 🧊💸","timeoutSeconds":60},"delivery":{"mode":"announce","channel":"telegram","to":"8212808444"},"state":{"nextRunAtMs":1775134800000,"lastRunAtMs":1775048443424,"lastRunStatus":"error","lastStatus":"error","lastDurationMs":60017,"lastDeliveryStatus