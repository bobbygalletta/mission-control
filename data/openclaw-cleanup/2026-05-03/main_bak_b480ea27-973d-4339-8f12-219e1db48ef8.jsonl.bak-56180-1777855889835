n-top: 40px; padding: 20px; font-size: 0.85em; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>🧠 Bobby's Brain</h1>\n            <p style=\"color: #8b949e; font-size: 0.85em;\">Unlimited memory · ${new Date().toISOString().split('T')[0]}</p>\n            <form action=\"/\" method=\"get\">\n                <input type=\"text\" name=\"search\" class=\"search-box\" placeholder=\"Search everything...\" value=\"${search ? escapeHtml(search) : ''}\">\n            </form>\n        </header>\n        ${agent_tabs}\n        ${nav}\n        ${content}\n        <footer>Bobby's Brain · ~/agent-mission-control/ · Updated every 30 min</footer>\n    </div>\n</body>\n</html>`;\n}\n\nfunction renderFolderView(folderPath) {\n    const relPath = folderPath || '';\n    const folderName = relPath ? path.basename(folderPath) : 'agent-mission-control';\n    const items = getFolderContents(relPath);\n    \n    // Breadcrumbs\n    let breadcrumbs = '<div class=\"breadcrumb\"><a href=\"/?view=files\">Files</a>';\n    if (relPath) {\n        const parts = relPath.split('/');\n        let build = '';\n        for (const p of parts) {\n            build += '/' + p;\n            breadcrumbs += ` / <a href=\"/?folder=${encodeURIComponent(build.substring(1))}\">${p}</a>`;\n        }\n    }\n    breadcrumbs += '</div>';\n    \n    let html = `<h2>📁 ${folderName}</h2>${breadcrumbs}`;\n    \n    if (items.length === 0) {\n        html += '<p>Empty folder.</p>';\n    } else {\n        html += '<div class=\"content\" style=\"padding:0;\">';\n        for (const item of items) {\n            const icon = item.type === 'folder' ? '📁' : '📄';\n            const size = item.size ? ` · ${(item.size/1024).toFixed(1)} KB` : '';\n            const ext = item.type === 'file' ? `<span class=\"ext\">${path.extname(item.name).replace('.','')}</span>` : '';\n            const link = item.type === 'folder' \n                ? `/?folder=${encodeURIComponent(item.path)}