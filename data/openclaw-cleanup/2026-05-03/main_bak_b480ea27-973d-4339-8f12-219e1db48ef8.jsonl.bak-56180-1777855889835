eturn [key for key, _ in sorted_sessions[:limit]]\n    except Exception as e:\n        print(f\"Error reading sessions for {agent_id}: {e}\")\n    return []\n\ndef get_session_history_raw(session_key):\n    \"\"\"Get raw message history from a session using openclaw CLI.\"\"\"\n    try:\n        result = subprocess.run(\n            [\"openclaw\", \"sessions\", \"history\", session_key, \"--json\", \"--limit\", \"50\"],\n            capture_output=True, text=True, timeout=30\n        )\n        if result.returncode == 0:\n            data = json.loads(result.stdout)\n            if isinstance(data, dict) and \"messages\" in data:\n                return data[\"messages\"]\n            return data if isinstance(data, list) else []\n    except Exception as e:\n        print(f\"Error getting history for {session_key}: {e}\")\n    return []\n\ndef load_state():\n    \"\"\"Load last logged session info.\"\"\"\n    if STATE_FILE.exists():\n        with open(STATE_FILE) as f:\n            return json.load(f)\n    return {}\n\ndef save_state(state):\n    \"\"\"Save state.\"\"\"\n    with open(STATE_FILE, \"w\") as f:\n        json.dump(state, f)\n\ndef log_conversation(session_key, agent_id, messages):\n    \"\"\"Log a conversation to today's daily log.\"\"\"\n    today = datetime.now().strftime(\"%Y-%m-%d\")\n    log_file = LOGS_DIR / f\"{today}.md\"\n    \n    # Create today's log if doesn't exist\n    if not log_file.exists():\n        with open(log_file, \"w\") as f:\n            f.write(f\"# {today} - Daily Log\\n\\n---\\n\\n\")\n    \n    # Extract meaningful exchanges (user msg followed by assistant msg)\n    entries = []\n    current_bobby = None\n    \n    for msg in messages:\n        role = msg.get(\"role\", \"\")\n        \n        # Handle content as list or string\n        content = msg.get(\"content\", \"\")\n        if isinstance(content, list):\n            content = \" \".join(c.get(\"text\", \"\") for c in content if isinstance(c, dict))\n        \n        if not content or len(content.strip()) < 2:\n            continue\n        \n        # Skip system messages and very short ones\n        if role == \"user\":\n            text = content.strip()\n            # Skip very short messages\n            if len(text) > 2:\n                current_bobby = text[:1000]\n        elif role == \"assistant\" and current_bobby:\n            # This is Bobby's message followed by agent's response\n            display_content = content[:800] + \"...\" if len(content) > 800 else content\n            entries.append((current_bobby, display_content))\n            current_bobby = None\n    \n    if entries:\n        with open(log_file, \"a\") as f:\n            f.write(f\"\\n### {agent_id.upper()} × Bobby\\n**Time:** {datetime.now().strftime('%H:%M')}\\n\\n\")\n            for bobby_msg, agent_msg in entries:\n                f.write(f\"**Bobby:** {bobby_msg}\\n\")\n                f.write(f\"**{agent_id.upper()}:** {agent_msg}\\n\\n\")\n\ndef main():\n    if len(sys.argv) < 2:\n        print(\"Usage: wiki-heartbeat.py <agent_id>\")\n        sys.exit(1)\n    \n    agent_id = sys.argv[1]\n    state = load_state()\n    state_key = f\"{agent_id}_last_session\"\n    \n    session_keys = get_recent_session_keys(agent_id, limit=5)\n    new_logs = 0\n    \n    for session_key in session_keys:\n        if not session_key:\n            continue\n        \n        # Skip if already processed (unless it's the current session which is always updating)\n        # Instead, track by timestamp\n        session_ts_key = f\"{agent_id}_last_ts\"\n        \n        # Get session data to check timestamp\n        sessions_path = get_sessions_json(agent_id)\n        if sessions_path:\n            try:\n                with open(sessions_path) as f:\n                    sessions = json.load(f)\n                session_data = sessions.get(session_key, {})\n                updated_at = session_data.get('updatedAt', 0)\n                \n                # Skip if 