"id":"call_function_2fmxgbuks25x_1","name":"write","arguments":{"content":"#!/usr/bin/env node\n/**\n * Bobby's Wiki - Local Host Server\n * Serves ~/agent-mission-control/ as a searchable web interface.\n * Access: http://localhost:8080 (local) or http://100.103.22.35:8080 (TailScale)\n */\n\nconst http = require('http');\nconst fs = require('fs');\nconst path = require('path');\nconst url = require('url');\n\nconst WIKI_ROOT = path.join(process.env.HOME, 'agent-mission-control');\nconst PORT = 8080;\n\nconst AGENTS = [\n    { id: 'main', name: 'Dean', emoji: '🤖🦞' },\n    { id: 'emmy', name: 'Emmy', emoji: '🦋📧' },\n    { id: 'finn', name: 'Finn', emoji: '🧊💸' },\n    { id: 'rex', name: 'Rex', emoji: '🔍📊' },\n    { id: 'x', name: 'Agent X', emoji: '⚡🕶️' },\n    { id: 'yoyos', name: 'YoYo', emoji: '🎥✨' },\n    { id: 'cody', name: 'Cody', emoji: '🧑‍💻' },\n    { id: 'dj', name: 'DJ', emoji: '🎧' },\n    { id: 'reese', name: 'Reese', emoji: '🍳' },\n    { id: 'tt', name: 'TT', emoji: '📱' }\n];\n\nconst TOPICS = ['YouTube', 'Money', 'Emails', 'Calendar', 'Research', 'Coding', 'Music', 'Food', 'TikTok', 'Twitter', 'Life', 'Health', 'Home', 'OpenClaw', 'Projects', 'Recipes'];\n\nfunction escapeHtml(str) {\n    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;');\n}\n\nfunction getDailyLogsForAgent(agent) {\n    const agent_id = (typeof agent === 'string' ? agent : agent.id).toUpperCase();\n    const logs_dir = path.join(WIKI_ROOT, 'memory-wiki', 'daily-logs');\n    if (!fs.existsSync(logs_dir)) return [];\n    const files = fs.readdirSync(logs_dir).filter(f => f.endsWith('.md')).sort().reverse();\n    const logs = [];\n    for (const f of files) {\n        const filePath = path.join(logs_dir, f);\n        const content = fs.readFileSync(filePath, 'utf-8');\n        if (content.includes(`### ${agent_id} × Bobby`)) {\n            const stats = fs.statSync(filePath);\n            logs.push({ date: f.replace('.md', ''), size: stats.size });\n        }\n    }\n    return logs;\n}\n\nfunction getDailyLogs() {\n    const logs_dir = path.join(WIKI_ROOT, 'memory-wiki', 'daily-logs');\n    if (!fs.existsSync(logs_dir)) return [];\n    return fs.readdirSync(logs_dir)\n        .filter(f => f.endsWith('.md'))\n        .map(f => {\n            const stats = fs.statSync(path.join(logs_dir, f));\n            return { date: f.replace('.md', ''), size: stats.size };\n        })\n        .sort((a, b) => b.date.localeCompare(a.date))\n        .slice(0, 30);\n}\n\nfunction getWikiPages() {\n    const wiki_dir = path.join(WIKI_ROOT, 'memory-wiki', 'wiki');\n    if (!fs.existsSync(wiki_dir)) return [];\n    return fs.readdirSync(wiki_dir)\n        .filter(f => f.endsWith('.md'))\n        .map(f => ({\n            name: path.basename(f, '.md').replace(/-/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase()),\n            path: 'wiki/' + f\n        }));\n}\n\nfunction getAllFolders(basePath, relPath = '') {\n    const fullPath = path.join(basePath, relPath);\n    const items = fs.readdirSync(fullPath, { withFileTypes: true });\n    const result = [];\n    \n    for (const item of items) {\n        if (item.name.startsWith('.') || item.name === 'node_modules') continue;\n        \n        const itemRel = relPath ? path.join(relPath, item.name) : item.name;\n        \n        if (item.isDirectory()) {\n            result.push({ name: item.name, path: itemRel, type: 'folder' });\n            // Add subfolder contents\n            const subItems = getAllFolders(fullPath, item.name);\n            for (const sub of subItems.slice(0, 5)) { // Limit subfolder preview\n                result.push({ name: sub.name, path: sub.path, type: 'file' });\n            }\n        } else {\n            result.push({ name: item.name, path: itemRel, type: 'file' });\n        }\n    }\n    return result;\n}\n\nfunction getFolderContents(folderPath) {\n    const fullPath = folderPath ? path.join(WIKI_ROOT, folderPath) : WIKI_ROOT;\n    if (!fs.existsSync(fullPath)) return [];\n    \n    const items = fs.readdirSync(fullPath, { withFileTypes: true });\n    return items\n        .filter(i => !i.name.startsWith('.') && i.name !== 'node_modules')\n        .map(i => ({\n            name: i.name,\n            path: folderPath ? path.join(folderPath, i.name) : i.name,\n            type: i.isDirectory() ? 'folder' : 'file',\n            size: i.isDirectory() ? null : fs.statSync(path.join(fullPath, i.name)).size\n        }))\n        .sort((a, b) => {\n            if (a.type !== b.type) return a.type === 'folder' ? -1 : 1;\n            return a.name.localeCompare(b.name);\n        });\n}\n\nfunction getFileContent(filePath) {\n    const fullPath = path.join(WIKI_ROOT, filePath);\n    if (!fs.existsSync(fullPath)) return null;\n    \n    const stats = fs.statSync(fullPath);\n    if (stats.isDirectory()) return { type: 'folder', contents: getFolderContents(filePath) };\n    \n    const ext = path.extname(filePath).toLowerCase();\n    const textExts = ['.md', '.txt', '.json', '.js', '.cjs', '.ts', '.py', '.sh', '.html', '.css', '.yml', '.yaml', '.toml', '.env', '.gitignore', '.mdx', '.log'];\n    const codeExts = ['.js', '.cjs', '.ts', '.py', '.sh', '.html', '.css', '.yml', '.yaml', '.json', '.toml', '.env', '.gitignore', '.log'];\n    \n    if (textExts.includes(ext) || ext === '') {\n        const content = fs.readFileSync(fullPath, 'utf-8');\n        const lines = content.split('\\n');\n        if (lines.length > 500) {\n            return { type: 'large_file', ext, size: stats.size, lines: lines.length, preview: lines.slice(0, 200).join('\\n') };\n        }\n        return { type: 'text', ext, content, size: stats.size, lines: lines.length };\n    }\n    \n    return { type: 'binary', ext, size: stats.size };\n}\n\nfunction renderAgentSection(agent) {\n    const logs = getDailyLogsForAgent(agent.id);\n    let html = `<h2>${agent.emoji} ${agent.name}</h2>`;\n    \n    // Topic filters\n    html += '<div style=\"display:flex;gap:8px;flex-wrap:wrap;margin:15px 0;\">';\n    for (const t of TOPICS) {\n        html += `<span style=\"background:#238636;padding:4px 10px;border-radius:12px;font-size:0.8em;cursor:pointer;\">${t}</span>`;\n    }\n    html += '</div>';\n    \n    if (logs.length === 0) {\n        html += '<p style=\"color: #8b949e;\">No conversations logged yet.</p>';\n    } else {\n        html += '<div class=\"grid\">';\n        for (const log of logs) {\n            const sizeKb = (log.size / 1024).toFixed(1);\n            html += `\n            <div class=\"card\">\n                <h3><a href=\"/?view=agent-log&agent=${agent.id}&date=${log.date}\">${log.date}</a></h3>\n                <div class=\"meta\">${sizeKb} KB</div>\n            </div>`;\n        }\n        html += '</div>';\n    }\n    return html;\n}\n\nfunction renderPage(parsed_query) {\n    const q = parsed_query;\n    const search = q.search || null;\n    const view = q.view || 'home';\n    const agent_filter = q.agent || null;\n    const date_filter = q.date || null;\n    const file = q.file || null;\n    const folder = q.folder || null;\n    const topics = q.topics || null;\n\n    const logs = getDailyLogs();\n    const pages = getWikiPages();\n\n    // Agent tabs\n    let agent_tabs = '<div class=\"agent-tabs\">';\n    agent_tabs += `<a href=\"/?view=home\" class=\"${view === 'home' ? 'active' : ''}\">🏠 Home</a>`;\n    for (const a of AGENTS) {\n        const isActive = view === 'agents' && agent_filter === a.id;\n        agent_tabs += `<a href=\"/?view=agents&agent=${a.id}\" class=\"${isActive ? 'active' : ''}\">${a.emoji} ${a.name}</a>`;\n    }\n    agent_tabs += '</div>';\n\n    const nav = `\n        <div class=\"nav\">\n            <a href=\"/?view=daily-logs\">📅 All Logs</a>\n            <a href=\"/?view=wiki\">📖 Wiki</a>\n            <a href=\"/?view=files\">📁 Files</a>\n            <a href=\"/?view=all-files\">🔍 All Files</a>\n        </div>`;\n\n    let content = '';\n\n    // Search\n    if (search) {\n        const results = searchWiki(search);\n        content = `<h2>🔍 Search: \"${escapeHtml(search)}\"</h2><p>${results.length} results</p>`;\n        for (const r of results) {\n            content += `<div class=\"search-result\">\n                <h4><a href=\"/?file=${encodeURIComponent(r.file)}\">${escapeHtml(r.file)}</a></h4>`;\n            for (const m of r.matches.slice(0, 3)) {\n                content += `<div class=\"match\">Line ${m.line}: ...${escapeHtml(m.text.substring(0, 120))}...</div>`;\n            }\n            content += '</div>';\n        }\n        if (results.length === 0) content += '<p>No results found.</p>';\n    }\n    // Agent + date view (full conversation)\n    else if (view === 'agent-log' && agent_filter && date_filter) {\n        const agent = AGENTS.find(a => a.id === agent_filter) || AGENTS[0];\n        const log_file = path.join(WIKI_ROOT, 'memory-wiki', 'daily-logs', `${date_filter}.md`);\n        if (fs.existsSync(log_file)) {\n            const content_raw = fs.readFileSync(log_file, 'utf-8');\n            const lines = content_raw.split('\\n');\n            let in_section = false;\n            let agent_lines = [];\n            let current_agent = '';\n            \n            for (const line of lines) {\n                const agent_match = line.match(/^### ([A-Z]+) × Bobby/);\n                if (agent_match) {\n                    current_agent = agent_match[1].toLowerCase();\n                    in_section = (current_agent === agent_filter.toLowerCase());\n                }\n                if (in_section) agent_lines.push(line);\n                if (current_agent !== agent_filter.toLowerCase() && line.startsWith('### ') && agent_lines.length > 0) break;\n            }\n            \n            const html_content = markdownToHtml(agent_lines.join('\\n'));\n            content = `\n                <a href=\"/?view=agents&agent=${agent_filter}\" class=\"back\">← Back to ${agent.emoji} ${agent.name}</a>\n                <div class=\"content\">${html_content}</div>`;\n        }\n    }\n    // Agent view\n    else if (view === 'agents' && agent_filter) {\n        const agent = AGENTS.find(a => a.id === agent_filter);\n        content = renderAgentSection(agent);\n    }\n    // All agents\n    else if (view === 'agents') {\n        content = '<h2>🤖 Agent Conversations</h2><p style=\"color:#8b949e;margin-bottom:20px;\">All conversations logged every 30 min. Click an agent to view their history.</p><div class=\"grid\">';\n        for (const a of AGENTS) {\n            const log_count = getDailyLogsForAgent(a).length;\n            content += `<div class=\"card\" style=\"padding:20px;\"><h3>${a.emoji} ${a.name}</h3><p style=\"color:#8b949e\">${log_count} day(s)</p><a href=\"/?view=agents&agent=${a.id}\" style=\"color:#58a6ff;\">View →</a></div>`;\n        }\n        content += '</div>';\n    }\n    // Single file view\n    else if (file) {\n        const fileData = getFileContent(decodeURIComponent(file));\n        if (fileData) {\n            if (fileData.type === 'folder') {\n                content = renderFolderView(file);\n            } else if (fileData.type === 'large_file') {\n                content = `\n                    <a href=\"/?view=files\" class=\"back\">← Back to Files</a>\n                    <div class=\"content\">\n                        <h2>📄 ${escapeHtml(path.basename(file))}</h2>\n                        <p style=\"color:#8b949e\">${fileData.lines} lines · ${(fileData.size/1024).toFixed(1)} KB</p>\n                        <hr style=\"border-color:#30363d;margin:15px 0;\">\n                        <pre style=\"white-space:pre-wrap;word-break:break-all;\">${escapeHtml(fileData.preview)}</pre>\n                        ${fileData.lines > 200 ? `<p style=\"color:#8b949e;margin-top:15px;\">... and ${fileData.lines - 200} more lines. Open the file directly to see full content.</p>` : ''}\n                    </div>`;\n            } else if (fileData.type === 'text') {\n                content = `\n                    <a href=\"/?view=files\" class=\"back\">← Back to Files</a>\n                    <div class=\"content\">\n                        <h2>📄 ${escapeHtml(path.basename(file))}</h2>\n                        <p style=\"color:#8b949e\">${fileData.lines} lines · ${(fileData.size/1024).toFixed(1)} KB</p>\n                        <hr style=\"border-color:#30363d;margin:15px 0;\">\n                        <pre style=\"white-space:pre-wrap;word-break:break-all;\">${escapeHtml(fileData.content)}</pre>\n                    </div>`;\n            } else {\n                content = `<a href=\"/?view=files\" class=\"back\">← Back to Files</a>\n                    <div class=\"content\">\n                        <h2>📄 ${escapeHtml(path.basename(file))}</h2>\n                        <p style=\"color:#8b949e\">Binary file · ${(fileData.size/1024).toFixed(1)} KB · Cannot preview in browser</p>\n                        <p style=\"margin-top:15px;\">Path: <code>${escapeHtml(file)}</code></p>\n                    </div>`;\n            }\n        } else {\n            content = '<p>File not found.</p>';\n        }\n    }\n    // Folder view\n    else if (folder) {\n        content = renderFolderView(folder);\n    }\n    // Files browser\n    else if (view === 'files' || view === 'all-files') {\n        content = renderFilesView(view === 'all-files' ? null : 'memory-wiki');\n    }\n    // Wiki pages\n    else if (view === 'wiki') {\n        content = '<h2>📖 Wiki Pages</h2><div class=\"grid\">';\n        for (const pg of pages) {\n            content += `<div class=\"card\"><h3><a href=\"/?file=${encodeURIComponent(pg.path)}\">${pg.name}</a></h3></div>`;\n        }\n        content += '</div>';\n    }\n    // Daily logs\n    else if (view === 'daily-logs') {\n        content = '<h2>📅 All Daily Logs</h2><div class=\"grid\">';\n        for (const log of logs) {\n            const kb = (log.size / 1024).toFixed(1);\n            content += `<div class=\"card\"><h3><a href=\"/?file=${encodeURIComponent('memory-wiki/daily-logs/' + log.date + '.md')}\">${log.date}</a></h3><div class=\"meta\">${kb} KB</div></div>`;\n        }\n        content += '</div>';\n    }\n    // Home\n    else {\n        content = `\n            <h2>📊 Bobby's Brain — Stats</h2>\n            <div class=\"grid\">\n                <div class=\"card\"><h3>${logs.length}</h3><p>Days Logged</p></div>\n                <div class=\"card\"><h3>${pages.length}</h3><p>Wiki Pages</p></div>\n                <div class=\"card\"><h3>${AGENTS.length}</h3><p>Agents</p></div>\n                <div class=\"card\"><h3>${TOPICS.length}</h3><p>Topics</p></div>\n            </div>\n            <h2>🏷️ Topics</h2>\n            <div style=\"display:flex;gap:8px;flex-wrap:wrap;margin:15px 0;\">`;\n        for (const t of TOPICS) {\n            content += `<a href=\"/?search=${encodeURIComponent(t)}\" style=\"background:#238636;padding:6px 14px;border-radius:16px;color:#fff;text-decoration:none;font-size:0.9em;\">${t}</a>`;\n        }\n        content += `</div>\n            <h2>🤖 Agent Conversations</h2>\n            <div class=\"grid\">`;\n        for (const a of AGENTS) {\n            const lc = getDailyLogsForAgent(a).length;\n            content += `<div class=\"card\" style=\"padding:20px;\"><h3 style=\"font-size:1.2em\">${a.emoji} ${a.name}</h3><p style=\"color:#8b949e;font-size:0.9em\">${lc} day(s)</p><a href=\"/?view=agents&agent=${a.id}\" style=\"color:#58a6ff\">View →</a></div>`;\n        }\n        content += '</div>';\n    }\n\n    return `<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bobby's Brain</title>\n    <style>\n        * { box-sizing: border-box; margin: 0; padding: 0; }\n        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0d1117; color: #c9d1d9; line-height: 1.6; }\n        .container { max-width: 1300px; margin: 0 auto; padding: 20px; }\n        header { background: #161b22; padding: 20px; border-radius: 8px; margin-bottom: 20px; border: 1px solid #30363d; }\n        h1 { color: #58a6ff; font-size: 1.8em; }\n        h2 { color: #c9d1d9; font-size: 1.3em; margin: 20px 0 10px; }\n        h3 { color: #c9d1d9; }\n        h4 { color: #58a6ff; }\n        .search-box { width: 100%; padding: 12px; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; color: #c9d1d9; font-size: 16px; margin-top: 15px; }\n        .search-box:focus { outline: none; border-color: #58a6ff; }\n        .nav { display: flex; gap: 10px; margin: 15px 0; flex-wrap: wrap; }\n        .nav a { color: #58a6ff; text-decoration: none; padding: 8px 16px; background: #161b22; border-radius: 6px; border: 1px solid #30363d; font-size: 0.9em; }\n        .nav a:hover { background: #1f6feb; }\n        .agent-tabs { display: flex; gap: 6px; margin: 15px 0; flex-wrap: wrap; padding: 10px; background: #161b22; border-radius: 8px; border: 1px solid #30363d; }\n        .agent-tabs a { color: #8b949e; text-decoration: none; padding: 7px 12px; border-radius: 6px; font-size: 0.85em; }\n        .agent-tabs a:hover { background: #30363d; color: #c9d1d9; }\n        .agent-tabs a.active { background: #1f6feb; color: #fff; }\n        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 15px; margin: 20px 0; }\n        .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 15px; }\n        .card h3 { color: #58a6ff; font-size: 1em; }\n        .card a { color: #c9d1d9; text-decoration: none; }\n        .card a:hover { color: #58a6ff; }\n        .card .meta { color: #8b949e; font-size: 0.85em; margin-top: 5px; }\n        pre { background: #0d1117; padding: 15px; border-radius: 6px; overflow-x: auto; border: 1px solid #30363d; margin: 10px 0; font-family: 'Monaco', 'Menlo', monospace; font-size: 0.85em; line-