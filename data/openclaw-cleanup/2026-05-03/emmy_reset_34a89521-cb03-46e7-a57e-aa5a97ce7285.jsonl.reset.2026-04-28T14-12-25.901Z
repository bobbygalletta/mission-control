a\",\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":null,\"addr\":\"ogcatering1597@olivegarden.com\"},\"date\":\"2025-05-19 15:34-04:00\",\"has_attachment\":false},{\"id\":\"1\",\"flags\":[\"Seen\"],\"subject\":\"Dissatisfied\",\"from\":{\"name\":\"Bobby Galletta\",\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":null,\"addr\":\"support@doordash.com\"},\"date\":\"2025-02-15 14:47-05:00\",\"has_attachment\":false}]"}],"details":{"status":"completed","exitCode":0,"durationMs":691,"aggregated":"[{\"id\":\"8\",\"flags\":[\"Seen\"],\"subject\":\"Re: Looking for new apartment\",\"from\":{\"name\":null,\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":\"Leasing RC\",\"addr\":\"RCLeasing@lexingtonpg.com\"},\"date\":\"2026-04-27 16:02-04:00\",\"has_attachment\":false},{\"id\":\"7\",\"flags\":[\"Seen\"],\"subject\":\"Re: Looking for new apartment\",\"from\":{\"name\":null,\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":\"Leasing RC\",\"addr\":\"RCLeasing@lexingtonpg.com\"},\"date\":\"2026-04-27 12:17-04:00\",\"has_attachment\":false},{\"id\":\"6\",\"flags\":[\"Seen\"],\"subject\":\"Re: Looking for new apartment\",\"from\":{\"name\":\"Robert Galletta\",\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":\"RC Leasing\",\"addr\":\"RCLeasing@lexingtonpg.com\"},\"date\":\"2026-04-25 17:54+00:00\",\"has_attachment\":false},{\"id\":\"5\",\"flags\":[\"Seen\"],\"subject\":\"Looking for new apartment\",\"from\":{\"name\":\"Bobby Galletta\",\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":null,\"addr\":\"rcleasing@lexingtonpg.com\"},\"date\":\"2026-04-13 11:12-04:00\",\"has_attachment\":false},{\"id\":\"4\",\"flags\":[\"Seen\"],\"subject\":\"Hello\",\"from\":{\"name\":\"Bobby Galletta\",\"addr\":\"rtg.bobby@icloud.com\"},\"to\":{\"name\":null,\"addr\":\"bobbysopenclawaiemail@gmail.com\"},\"date\":\"2026-01-31 18:05-05:00\",\"has_attachment\":false},{\"id\":\"3\",\"flags\":[\"Seen\"],\"subject\":\"Apartment Inquiry (Around mid June)\",\"from\":{\"name\":\"Bobby Galletta\"