ce.users().messages().get(userId='me', id=m['id'], format='full').execute()\n-202     headers = {h['name']: h['value'] for h in msg['payload'].get('headers', [])}\n-203     sender = headers.get('From', '')\n-204     subject = headers.get('Subject', '')\n-205     date_h = headers.get('Date', '')\n-206     labels = msg.get('labelIds', [])\n-207     is_unread = 'UNREAD' in labels\n-208     print(f'[{\"UNREAD\" if is_unread else \"READ\"}] {sender[:30]} | {subject[:60]}')\n+171 **CRITICAL:** The old Python/Gmail API script is BROKEN (auth expired). Always use gog instead!\n 209 ```\n 210 \n 211 **IMPORTANT:**\n 212 - ALWAYS use Gmail API directly, NOT gog CLI\n     ...","firstChangedLine":162},"isError":false,"timestamp":1775471761669}}
