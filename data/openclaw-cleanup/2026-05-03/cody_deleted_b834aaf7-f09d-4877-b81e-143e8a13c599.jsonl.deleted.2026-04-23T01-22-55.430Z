    right: '10%',\n          background:\n            'radial-gradient(circle, rgba(109,40,217,0.45) 0%, rgba(76,29,149,0.2) 50%, transparent 70%)',\n        }}\n      />\n\n      {/* Orb 5 — deep pink/magenta accent, bottom-right */}\n      <div\n        className=\"orb-5 absolute rounded-full blur-3xl\"\n        style={{\n          width: '35vw',\n          height: '35vw',\n          maxWidth: '450px',\n          maxHeight: '450px',\n          bottom: '5%',\n          right: '-5%',\n          background:\n            'radial-gradient(circle, rgba(88,28,135,0.4) 0%, rgba(40,10,60,0.2) 50%, transparent 70%)',\n        }}\n      />\n\n      {/* Orb 6 — bright indigo glow, center-left */}\n      <div\n        className=\"orb-6 absolute rounded-full blur-3xl\"\n        style={{\n          width: '30vw',\n          height: '30vw',\n          maxWidth: '380px',\n          maxHeight: '380px',\n          top: '35%',\n          left: '5%',\n          background:\n            'radial-gradient(circle, rgba(55,65,160,0.5) 0%, rgba(30,30,100,0.25) 50%, transparent 70%)',\n        }}\n      />\n\n      {/* Subtle noise texture overlay for depth */}\n      <div\n        className=\"absolute inset-0 opacity-[0.03]\"\n        style={{\n          backgroundImage: `url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E\")`,\n        }}\n      />\n\n      {/* Vignette — darkens edges */}\n      <div\n        className=\"absolute inset-0\"\n        style={{\n          background:\n            'radial-gradient(ellipse 100% 100% at 50% 50%, transparent 40%, rgba(8,8,14,0.6) 100%)',\n        }}\n      />\n    </div>\n  );\n};\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":12758,"output":1584,"cach