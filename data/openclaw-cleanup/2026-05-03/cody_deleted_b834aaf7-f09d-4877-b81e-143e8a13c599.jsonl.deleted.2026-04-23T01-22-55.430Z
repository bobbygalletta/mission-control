 initialized } = useAgentStatus(3000);\n  const [selectedAgent, setSelectedAgent] = useState<Agent | null>(null);\n  const [toast, setToast] = useState<string | null>(null);\n\n  const handleAgentClick = useCallback((agent: Agent) => {\n    setSelectedAgent(agent);\n  }, []);\n\n  return ("}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":8983,"output":489,"cacheRead":16299,"cacheWrite":0,"totalTokens":25771,"cost":{"input":0.0026949,"output":0.0005868,"cacheRead":0.0009779399999999998,"cacheWrite":0,"total":0.00425964}},"stopReason":"toolUse","timestamp":1774312842483,"responseId":"0611108a3d84ea77f782d59dfe2314e0"}}
