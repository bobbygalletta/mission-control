{"type":"message","id":"01af1a0e","parentId":"f59a8a5e","timestamp":"2026-03-24T00:40:42.462Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me update the MessageModal.tsx to be a full chat interface for Dean and show a \"coming soon\" message for other agents.","thinkingSignature":"f8d6b4029b2da175e998416ac532d492fcc329f8c634146aee23c299dcb629b8"},{"type":"text","text":"Now let me rebuild MessageModal as a full chat interface:\n"},{"type":"toolCall","id":"call_function_vz7a76soy5z5_1","name":"write","arguments":{"path":"/Users/bobbygalletta/agent-mission-control/src/components/MessageModal.tsx","content":"import { useEffect, useRef, useState, useCallback } from 'react';\nimport type { Agent } from '../types';\nimport { sendChatMessage } from '../lib/gateway';\n\nexport interface ChatMessage {\n  id: string;\n  role: 'user' | 'assistant';\n  content: string;\n  timestamp: number;\n}\n\ninterface MessageModalProps {\n  agent: Agent | null;\n  onClose: () => void;\n}\n\n// Dean (agentId \"main\") gets the full chat interface\nconst DEAN_ID = 'main';\nconst DEAN_SESSION_KEY = 'agent:main:telegram:direct:8212808444';\n\nfunction formatTime(ts: number): string {\n  return new Date(ts).toLocaleTimeString('en-US', {\n    hour: 'numeric',\n    minute: '2-digit',\n    hour12: true,\n  });\n}\n\nfunction generateId(): string {\n  return `msg-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`;\n}\n\nexport const MessageModal = ({ agent, onClose }: MessageModalProps) => {\n  const [messages, setMessages] = useState<ChatMessage[]>([]);\n  const [input, setInput] = useState('');\n  const [isLoading, setIsLoading] = useState(false);\n  const messagesEndRef = useRef<HTMLDivElement>(null);\n  const textareaRef = useRef<HTMLTextAreaElement>(null);\n\n  // Scroll to bottom whenever messages change\n  useEffect(() => {\n    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });\n  }, [messages]);\n\n  // Auto-focus input when modal opens\n  useEffect(() => {\n    if (agent) {\n      textareaRef.current?.focus();\n    }\n  }, [agent]);\n\n  // Keyboard shortcuts\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => {\n      if (e.key === 'Escape') onClose();\n    };\n    window.addEventListener('keydown', handleKeyDown);\n    return () => window.removeEventListener('keydown', handleKeyDown);\n  }, [onClose]);\n\n  const handleSend = useCallback(async () => {\n    if (!input.trim() || isLoading || !agent) return;\n\n    const userMsg: ChatMessage = {\n      id: generateId(),\n      role: 'user',\n      content: input.trim(),\n      timestamp: Date.now(),\n    };\n\n    setMessages(prev => [...prev, userMsg]);\n    setInput('');\n    setIsLoading(true);\n\n    try {\n      const response = await sendChatMessage(\n        DEAN_ID,\n        input.trim(),\n        DEAN_SESSION_KEY\n      );\n\n      const assistantMsg: ChatMessage = {\n        id: generateId(),\n        role: 'assistant',\n        content: response,\n        timestamp: Date.now(),\n      };\n\n      setMessages(prev => [...prev, assistantMsg]);\n    } catch (err) {\n      const errorMsg: ChatMessage = {\n        id: generateId(),\n        role: 'assistant',\n        content: 'Failed to get a response. Please try again.',\n        timestamp: Date.now(),\n      };\n      setMessages(prev => [...prev, errorMsg]);\n    } finally {\n      setIsLoading(false);\n      textareaRef.current?.focus();\n    }\n  }, [input, isLoading, agent]);\n\n  const handleKeyDown = (e: React.KeyboardEvent) => {\n    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {\n      e.preventDefault();\n      handleSend();\n    }\n  };\n\n  const handleInputKeyDown = (e: React.KeyboardEvent<HTMLTextAreaElement>) => {\n    if (e.key === 'Enter' && !e.shiftKey) {\n      e.preventDefault();\n      handleSend();\n    }\n  };\n\n  if (!agent) return null;\n\n  // ── Other agents: \"coming soon\" state ─────────────────────────────────────\n  if (agent.id !== DEAN_ID) {\n    return (\n      <div\n        className=\"fixed inset-0 z-50 flex items-center justify-center p-4\"\n        onClick={(e) => e.target === e.currentTarget && onClose()}\n      >\n        <div className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" />\n        <div\n          className=\"\n            relative w-full max-w-md\n            backdrop-blur-xl bg-white/[0.06] border border-white/15 rounded-2xl\n            shadow-[0_25px_50px_rgba(0,0,0,0.6)]\n            flex flex-col gap-5 p-7\n          \"\n          style={{ animation: 'fadeIn 0.2s ease-out' }}\n        >\n          {/* Header */}\n          <div className=\"flex items-center justify-between\">\n            <div className=\"flex items-center gap-3\">\n              <span className=\"text-3xl\">{agent.emoji}</span>\n              <div>\n                <h2 className=\"text-lg font-semibold text-slate-100\">{agent.name}</h2>\n                <p className=\"text-xs text-slate-400\">{agent.role}</p>\n              </div>\n            </div>\n            <button\n              onClick={onClose}\n              className=\"w-8 h-8 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-slate-400 hover:text-slate-200 transition-colors\"\n              aria-label=\"Close\"\n            >\n              ✕\n            </button>\n          </div>\n\n          <div className=\"h-px bg-white/10\" />\n\n          {/* Coming soon */}\n          <div className=\"flex flex-col items-center gap-4 py-6 text-center\">\n            <div className=\"text-5xl\">{agent.emoji}</div>\n            <div>\n              <p className=\"text-slate-200 font-medium\">Chat coming soon for {agent.name}</p>\n              <p className=\"text-slate-500 text-sm mt-1\">\n                Direct messaging for {agent.name} is in the works. Hang tight!\n              </p>\n            </div>\n          </div>\n\n          <button\n            onClick={onClose}\n            className=\"\n              w-full py-3 rounded-xl font-semibold text-sm\n              bg-white/10 hover:bg-white/15 text-slate-300\n              border border-white/10 transition-colors\n            \"\n          >\n            Got it\n          </button>\n        </div>\n      </div>\n    );\n  }\n\n  // ── Dean: Full chat interface ──────────────────────────────────────────────\n  return (\n    <div\n      className=\"fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6\"\n      onClick={(e) => e.target === e.currentTarget && onClose()}\n    >\n      <div className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" />\n\n      {/* Chat container */}\n      <div\n        className=\"\n          relative w-full max-w-lg h-[640px] max-h-[85vh]\n          backdrop-blur-xl bg-white/[0.06] border border-white/15 rounded-2xl\n          shadow-[0_25px_50px_rgba(0,0,0,0.6),0_0_80px_rgba(129,140,248,0.1)]\n          flex flex-col overflow-hidden\n        \"\n        style={{ animation: 'fadeIn 0.2s ease-out' }}\n      >\n        {/* Header */}\n        <div className=\"flex items-center justify-between px-5 py-4 border-b border-white/10 shrink-0\">\n          <div className=\"flex items-center gap-3\">\n            <span className=\"text-2xl\">{agent.emoji}</span>\n            <div>\n              <h2 className=\"text-base font-semibold text-slate-100\">{agent.name}</h2>\n              <p className=\"text-xs text-slate-400\">Direct chat</p>\n            </div>\n          </div>\n          <button\n            onClick={onClose}\n            className=\"w-8 h-8 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-slate-400 hover:text-slate-200 transition-colors\"\n            aria-label=\"Close\"\n          >\n            ✕\n          </button>\n        </div>\n\n        {/* Messages area */}\n        <div className=\"flex-1 overflow-y-auto px-4 py-4 flex flex-col gap-3\">\n          {messages.length === 0 && (\n            <div className=\"flex flex-col items-center justify-center h-full gap-3 text-center\">\n              <span className=\"text-4xl\">{agent.emoji}</span>\n              <p className=\"text-slate-400 text-sm\">\n                Chat with Dean — powered by your AI team\n              </p>\n            </div>\n          )}\n\n          {messages.map((msg) =>\n            msg.role === 'user' ? (\n              <div key={msg.id} className=\"flex justify-end\">\n                <div className=\"max-w-[80%]\">\n                  <div\n                    className=\"\n                      rounded-2xl rounded-tr-sm px-4 py-2.5\n                      bg-gradient-to-r from-accent-indigo to-accent-violet\n                      text-white text-sm leading-relaxed\n                      shadow-[0_4px_16px_rgba(129,140,248,0.35)]\n                    \"\n                  >\n                    {msg.content}\n                  </div>\n                  <p className=\"text-[10px] text-slate-600 mt-1 text-right pr-1\">\n                    {formatTime(msg.timestamp)}\n                  </p>\n                </div>\n              </div>\n            ) : (\n              <div key={msg.id} className=\"flex justify-start\">\n                <div className=\"max-w-[80%]\">\n                  <div\n                    className=\"\n                      rounded-2xl rounded-tl-sm px-4 py-2.5\n                      bg-white/[0.07] border border-white/[0.08]\n                      text-slate-200 text-sm leading-relaxed\n                      backdrop-blur-sm\n                    \"\n                  >\n                    <span className=\"mr-1.5\">🤖</span>\n                    {msg.content}\n                  </div>\n                  <p className=\"text-[10px] text-slate-600 mt-1 text-left pl-1\">\n                    {formatTime(msg.timestamp)}\n                  </p>\n                </div>\n              </div>\n            )\n          )}\n\n          {/* Typing indicator */}\n          {isLoading && (\n            <div className=\"flex justify-start\">\n              <div className=\"max-w-[80%]\">\n                <div\n                  className=\"\n                    rounded-2xl rounded-tl-sm px-4 py-3\n                    bg-white/[0.07] border border-white/[0.08]\n                    backdrop-blur-sm\n                  \"\n                >\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"mr-1.5 text-sm\">🤖</span>\n                    <span className=\"flex gap-1\">\n                      <span className=\"w-1.5 h-1.5 rounded-full bg-slate-400 animate-bounce\" style={{ animationDelay: '0ms' }} />\n                      <span className=\"w-1.5 h-1.5 rounded-full bg-slate-400 animate-bounce\" style={{ animationDelay: '160ms' }} />\n                      <span className=\"w-1.5 h-1.5 rounded-full bg-slate-400 animate-bounce\" style={{ animationDelay: '320ms' }} />\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          <div ref={messagesEndRef} />\n        </div>\n\n        {/* Input bar */}\n        <div className=\"shrink-0 px-4 pb-4 pt-2 border-t border-white/10\">\n          <div\n            className=\"\n              flex items-end gap-2\n              backdrop-blur-md bg-white/[0.07] border border-white/[0.12]\n              rounded-2xl px-3 py-2\n            \"\n          >\n            <textarea\n              ref={textareaRef}\n              value={input}\n              onChange={e => setInput(e.target.value)}\n              onKeyDown={handleInputKeyDown}\n              placeholder={`Message ${agent.name}...`}\n              rows={1}\n              className=\"\n                flex-1 bg-transparent text-slate-200 placeholder-slate-500\n                text-sm leading-relaxed resize-none outline-none\n                py-1 max-h-32 overflow-y-auto\n              \"\n              style={{ minHeight: '24px' }}\n            />\n            <button\n              onClick={handleSend}\n              disabled={!input.trim() || isLoading}\n              className=\"\n                shrink-0 w-8 h-8 flex items-center justify-center\n                rounded-xl\n                bg-gradient-to-r from-accent-indigo to-accent-violet\n                text-white text-sm\n                disabled:opacity-30 disabled:cursor-not-allowed\n                hover:shadow-[0_4px_16px_rgba(129,140,248,0.5)]\n                transition-all duration-150\n              \"\n              aria-label=\"Send\"\n            >\n              ↑\n            </button>\n          </div>\n          <p className=\"text-[10px] text-slate-600 mt-1.5 text-center\">\n            Press{' '}\n            <kbd className=\"px-1 py-0.5 rounded bg-white/10 text-slate-500 font-mono\">⌘</kbd>{' '}\n            or{' '}\n            <kbd className=\"px-1 py-0.5 rounded bg-white/10 text-slate-500 font-mono\">↵</kbd>{' '}\n            to send\n          </p>\n        </div>\n      </div>\n    </div>\n  );\n};\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":5888,"output":3054,"cacheRead":16299,"cacheWrite":0,"totalTokens":25241,"cost":{"input":0.0017664,"output":0.0036647999999999997,"cacheRead":0.0009779399999999998,"cacheWrite":0,"total":0.00640914}},"stopReason":"toolUse","timestamp":1774312792151,"responseId":"06111058fc3b23ba4db5acd84067ca05"}}
